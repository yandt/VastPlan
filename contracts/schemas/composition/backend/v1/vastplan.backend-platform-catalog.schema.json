{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/composition/backend/v1/vastplan.backend-platform-catalog.schema.json",
  "title": "VastPlan Backend Platform Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "id", "profiles", "bindings"],
  "properties": {
    "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/version" },
    "revision": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/revision" },
    "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/compositionId" },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/backend/v1/vastplan.platform-profile.schema.json" }
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tenantId", "deploymentName", "platformProfile"],
        "properties": {
          "tenantId": { "type": "string", "minLength": 1, "maxLength": 160 },
          "deploymentName": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/compositionId" },
          "platformProfile": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/compositionRef" }
        }
      }
    }
  }
}
