{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/composition/backend/v1/vastplan.application-composition.schema.json",
  "title": "VastPlan Backend Application Composition v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "id", "target", "metadata", "units"],
  "properties": {
    "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/version" },
    "revision": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/revision" },
    "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/compositionId" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kernel"],
      "properties": { "kernel": { "const": "backend" } }
    },
    "metadata": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/deployment/v2/vastplan.deployment.schema.json#/$defs/deploymentMetadata" },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["serviceClass", "spec"],
        "properties": {
          "serviceClass": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" },
          "spec": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/deployment/v2/vastplan.deployment.schema.json#/$defs/serviceUnit" }
        }
      }
    }
  }
}
