{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/composition/frontend/v1/vastplan.platform-profile.schema.json",
  "title": "VastPlan Frontend Platform Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "id", "target", "renderAdapter", "shell", "workbench", "plugins", "security"],
  "properties": {
    "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/version" },
    "revision": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/revision" },
    "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/compositionId" },
    "target": { "type": "object", "additionalProperties": false, "required": ["kernel"], "properties": { "kernel": { "const": "frontend" } } },
    "renderAdapter": { "$ref": "#/$defs/renderAdapter" },
    "shell": { "$ref": "#/$defs/shellSelection" },
    "workbench": { "$ref": "#/$defs/workbenchSelection" },
    "localization": { "$ref": "#/$defs/localizationPolicy" },
    "updates": {
      "type": "object", "additionalProperties": false, "required": ["mode"],
      "properties": { "mode": { "enum": ["refresh", "notify", "automatic"] } }
    },
    "plugins": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/pluginRef" } },
    "security": {
      "type": "object", "additionalProperties": false,
      "required": ["firstPartyOnly", "requireIntegrity"],
      "properties": { "firstPartyOnly": { "const": true }, "requireIntegrity": { "const": true } }
    }
  },
  "$defs": {
    "pluginRef": {
      "type": "object", "additionalProperties": false, "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" }
      }
    },
    "renderAdapter": {
      "type": "object", "additionalProperties": false, "required": ["id", "version", "uiContract", "config"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" },
        "uiContract": { "type": "string", "pattern": "^(?:\\^)?4\\.", "maxLength": 128 },
        "config": { "$ref": "#/$defs/renderAdapterConfig" }
      }
    },
    "shellSelection": {
      "type": "object", "additionalProperties": false, "required": ["id", "version", "uiContract"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" },
        "uiContract": { "type": "string", "pattern": "^(?:\\^)?4\\.", "maxLength": 128 },
        "config": { "$ref": "#/$defs/shellConfig" }
      }
    },
    "workbenchSelection": {
      "type": "object", "additionalProperties": false, "required": ["id", "version", "uiContract"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" },
        "uiContract": { "type": "string", "pattern": "^(?:\\^)?4\\.", "maxLength": 128 },
        "config": { "$ref": "#/$defs/workbenchConfig" }
      }
    },
    "navigationConfig": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "navigationGroups": {
          "type": "array", "maxItems": 256,
          "items": { "$ref": "#/$defs/navigationGroup" }
        }
      }
    },
    "shellConfig": {
      "type": "object", "additionalProperties": false,
      "required": ["defaultTemplate", "allowedTemplates", "userSelectable"],
      "properties": {
        "navigationGroups": {
          "type": "array", "maxItems": 256,
          "items": { "$ref": "#/$defs/navigationGroup" }
        },
        "defaultTemplate": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
        "allowedTemplates": {
          "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" }
        },
        "userSelectable": { "type": "boolean" },
        "templateOptions": {
          "type": "object",
          "propertyNames": { "pattern": "^[a-z][a-z0-9-]{0,63}$" },
          "additionalProperties": { "type": "object" }
        }
      }
    },
    "renderAdapterConfig": {
      "type": "object", "additionalProperties": false,
      "required": ["defaultRenderer", "allowedRenderers", "userSelectable"],
      "properties": {
        "defaultRenderer": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
        "allowedRenderers": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" } },
        "userSelectable": { "type": "boolean" },
        "rendererOptions": { "type": "object", "propertyNames": { "pattern": "^[a-z][a-z0-9-]{0,63}$" }, "additionalProperties": { "type": "object", "additionalProperties": false, "properties": { "themeTemplate": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" } } } }
      }
    },
    "workbenchConfig": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "collection": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "defaultDensity": { "enum": ["compact", "standard", "comfortable"] },
            "allowedDensities": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "enum": ["compact", "standard", "comfortable"] } }
          }
        }
      }
    },
    "navigationGroup": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "label", "zone", "icon"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,159}$" },
        "parentID": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,159}$" },
        "label": { "type": "string", "minLength": 1, "maxLength": 80 },
        "zone": { "enum": ["primary", "secondary", "settings"] },
        "icon": { "enum": ["add", "remove", "edit", "search", "settings", "success", "warning", "error", "info", "close", "menu"] },
        "order": { "type": "integer", "minimum": -1000000, "maximum": 1000000 }
      }
    },
    "localizationPolicy": {
      "type": "object", "additionalProperties": false, "required": ["defaultLocale", "supportedLocales"],
      "properties": {
        "defaultLocale": { "type": "string", "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$", "maxLength": 64 },
        "supportedLocales": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z]{2,8}(?:-[A-Za-z0-9]{1,8})*$", "maxLength": 64 } }
      }
    }
  }
}
