{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-store.schema.json",
  "title": "VastPlan Authorization Store Protocol v1",
  "$defs": {
    "empty": { "type": "object", "additionalProperties": false },
    "storeDocument": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "format": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$", "maxLength": 160 },
        "schemaVersion": { "type": "string", "pattern": "^v[1-9][0-9]*$" },
        "revision": { "type": "integer", "minimum": 1 },
        "digest": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/digest" },
        "content": { "type": "object" }
      },
      "required": ["format", "schemaVersion", "revision", "digest", "content"]
    },
    "probeRequest": { "$ref": "#/$defs/empty" },
    "probeResult": {
      "type": "object", "additionalProperties": false,
      "properties": { "ready": { "type": "boolean" }, "providerId": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" }, "observedRevision": { "type": "integer", "minimum": 0 } },
      "required": ["ready", "providerId", "observedRevision"]
    },
    "loadRequest": {
      "type": "object", "additionalProperties": false,
      "properties": { "domainId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/domainId" }, "minRevision": { "type": "integer", "minimum": 0 } },
      "required": ["domainId", "minRevision"]
    },
    "loadResult": {
      "type": "object", "additionalProperties": false,
      "properties": { "found": { "type": "boolean" }, "document": { "$ref": "#/$defs/storeDocument" }, "etag": { "type": "string", "minLength": 1, "maxLength": 256 } },
      "required": ["found"]
    },
    "compareAndSwapRequest": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "domainId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/domainId" },
        "expectedRevision": { "type": "integer", "minimum": 0 },
        "expectedEtag": { "type": "string", "minLength": 1, "maxLength": 256 },
        "idempotencyKey": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{15,127}$" },
        "document": { "$ref": "#/$defs/storeDocument" }
      },
      "required": ["domainId", "expectedRevision", "idempotencyKey", "document"]
    },
    "compareAndSwapResult": {
      "type": "object", "additionalProperties": false,
      "properties": { "applied": { "type": "boolean" }, "revision": { "type": "integer", "minimum": 0 }, "etag": { "type": "string", "minLength": 1, "maxLength": 256 } },
      "required": ["applied", "revision", "etag"]
    },
    "watchRequest": {
      "type": "object", "additionalProperties": false,
      "properties": { "domainId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/domainId" }, "cursor": { "type": "string", "maxLength": 512 }, "limit": { "type": "integer", "minimum": 1, "maximum": 1000 } },
      "required": ["domainId", "limit"]
    },
    "storeChange": {
      "type": "object", "additionalProperties": false,
      "properties": { "revision": { "type": "integer", "minimum": 1 }, "digest": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/digest" }, "cursor": { "type": "string", "minLength": 1, "maxLength": 512 }, "changedAt": { "type": "string", "format": "date-time" } },
      "required": ["revision", "digest", "cursor", "changedAt"]
    },
    "watchResult": {
      "type": "object", "additionalProperties": false,
      "properties": { "changes": { "type": "array", "items": { "$ref": "#/$defs/storeChange" }, "maxItems": 1000 }, "nextCursor": { "type": "string", "maxLength": 512 } },
      "required": ["changes", "nextCursor"]
    },
    "auditRecord": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "eventId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/stableId" },
        "domainId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/domainId" },
        "policyRevision": { "type": "integer", "minimum": 1 },
        "action": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$", "maxLength": 160 },
        "subject": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/subject" },
        "occurredAt": { "type": "string", "format": "date-time" },
        "details": { "type": "object", "maxProperties": 64 }
      },
      "required": ["eventId", "domainId", "policyRevision", "action", "subject", "occurredAt", "details"]
    },
    "appendAuditRequest": {
      "type": "object", "additionalProperties": false,
      "properties": { "idempotencyKey": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{15,127}$" }, "record": { "$ref": "#/$defs/auditRecord" } },
      "required": ["idempotencyKey", "record"]
    },
    "appendAuditResult": {
      "type": "object", "additionalProperties": false,
      "properties": { "accepted": { "type": "boolean" }, "auditRevision": { "type": "integer", "minimum": 1 } },
      "required": ["accepted", "auditRevision"]
    },
    "backupRequest": {
      "type": "object", "additionalProperties": false,
      "properties": { "domainId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/domainId" }, "revision": { "type": "integer", "minimum": 1 } },
      "required": ["domainId", "revision"]
    },
    "backupResult": {
      "type": "object", "additionalProperties": false,
      "properties": { "artifactUri": { "type": "string", "pattern": "^artifact://[A-Za-z0-9._/-]+$", "maxLength": 512 }, "sha256": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/authorization/v1/vastplan.authorization-types.schema.json#/$defs/digest" }, "sizeBytes": { "type": "integer", "minimum": 1 }, "createdAt": { "type": "string", "format": "date-time" } },
      "required": ["artifactUri", "sha256", "sizeBytes", "createdAt"]
    }
  }
}
