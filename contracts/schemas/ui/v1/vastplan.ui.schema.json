{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/ui/v1/vastplan.ui.schema.json",
  "title": "VastPlan UI Contract v1 JSON Schema Form",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "schema"],
  "properties": {
    "id": { "type": "string", "minLength": 1, "maxLength": 160 },
    "schema": {
      "type": "object",
      "required": ["$schema", "type", "properties"],
      "properties": {
        "$schema": { "const": "http://json-schema.org/draft-07/schema#" },
        "type": { "const": "object" },
        "properties": { "type": "object" }
      },
      "additionalProperties": true
    },
    "uiSchema": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
