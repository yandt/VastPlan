{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/api/v1/vastplan.api-exposure.schema.json",
  "title": "VastPlan Governed API Exposure v1",
  "$defs": {
    "governedId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$", "maxLength": 160 },
    "stableId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@/-]{0,255}$" },
    "localId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,63}$" },
    "serviceRole": { "enum": ["backend", "workspace", "rs"] },
    "semver": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$", "maxLength": 64 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "routeKey": { "type": "string", "pattern": "^[a-z2-7]{20}$" },
    "host": { "type": "string", "pattern": "^(?:[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.)*[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$", "maxLength": 253 },
    "routePath": { "type": "string", "pattern": "^/(?:[a-z0-9][a-z0-9._~-]*|\\{[a-z][A-Za-z0-9]*\\})(?:/(?:[a-z0-9][a-z0-9._~-]*|\\{[a-z][A-Za-z0-9]*\\}))*$", "maxLength": 512 },
    "capabilityTarget": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "capability": { "$ref": "#/$defs/governedId" },
        "operation": { "type": "string", "pattern": "^[a-z][A-Za-z0-9]*(?:[._-][A-Za-z0-9]+)*$", "maxLength": 160 }
      },
      "required": ["capability", "operation"]
    },
    "errorMapping": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/governedId" },
        "status": { "enum": [400, 401, 403, 404, 409, 412, 422, 429, 502, 503, 504] }
      },
      "required": ["code", "status"]
    },
    "routeContract": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/governedId" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "$ref": "#/$defs/routePath" },
        "target": { "$ref": "#/$defs/capabilityTarget" },
        "requestSchema": { "type": "object" },
        "responseSchema": { "type": "object" },
        "successStatus": { "enum": [200, 201, 202, 204] },
        "errors": { "type": "array", "maxItems": 32, "items": { "$ref": "#/$defs/errorMapping" } }
      },
      "required": ["id", "method", "path", "target", "requestSchema", "responseSchema", "successStatus"]
    },
    "apiContractContribution": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "service_role": { "$ref": "#/$defs/serviceRole" },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "contractId": { "$ref": "#/$defs/governedId" },
        "contractVersion": { "$ref": "#/$defs/semver" },
        "protocol": { "const": "http-json" },
        "routes": { "type": "array", "minItems": 1, "maxItems": 256, "items": { "$ref": "#/$defs/routeContract" } }
      },
      "required": ["id", "service_role", "contractId", "contractVersion", "protocol", "routes"]
    },
    "dataPlaneMode": { "enum": ["gateway-proxy", "ticket-redirect", "private-direct"] },
    "dataPlaneServiceContribution": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/localId" },
        "service_role": { "$ref": "#/$defs/serviceRole" },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "protocol": { "const": "https" },
        "purposes": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/localId" } },
        "supportedModes": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/dataPlaneMode" } },
        "healthPath": { "type": "string", "pattern": "^/[a-z0-9][a-z0-9/_-]{0,127}$" },
        "maxObjectBytes": { "type": "integer", "minimum": 1, "maximum": 1099511627776 },
        "ticketTarget": { "$ref": "#/$defs/capabilityTarget" }
      },
      "required": ["id", "service_role", "protocol", "purposes", "supportedModes", "healthPath", "maxObjectBytes"],
      "allOf": [{
        "if": { "properties": { "supportedModes": { "contains": { "const": "ticket-redirect" } } } },
        "then": { "required": ["ticketTarget"] }
      }]
    },
    "contractReference": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "pluginId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$", "maxLength": 200 },
        "artifactSha256": { "$ref": "#/$defs/sha256" },
        "contributionId": { "$ref": "#/$defs/localId" },
        "contractId": { "$ref": "#/$defs/governedId" },
        "contractVersion": { "$ref": "#/$defs/semver" },
        "contractDigest": { "$ref": "#/$defs/sha256" }
      },
      "required": ["pluginId", "artifactSha256", "contributionId", "contractId", "contractVersion", "contractDigest"]
    },
    "resolvedContract": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "reference": { "$ref": "#/$defs/contractReference" },
        "contract": { "$ref": "#/$defs/apiContractContribution" }
      },
      "required": ["reference", "contract"]
    },
    "dataPlaneServiceReference": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "pluginId": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)+$", "maxLength": 200 },
        "artifactSha256": { "$ref": "#/$defs/sha256" },
        "contributionId": { "$ref": "#/$defs/localId" }
      },
      "required": ["pluginId", "artifactSha256", "contributionId"]
    },
    "resolvedDataPlaneService": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "reference": { "$ref": "#/$defs/dataPlaneServiceReference" },
        "service": { "$ref": "#/$defs/dataPlaneServiceContribution" }
      },
      "required": ["reference", "service"]
    },
    "contractCatalog": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": "v1" },
        "generation": { "type": "integer", "minimum": 1 },
        "contracts": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/resolvedContract" } },
        "dataPlaneServices": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/resolvedDataPlaneService" } }
      },
      "required": ["schemaVersion", "generation", "contracts", "dataPlaneServices"]
    },
    "authenticationPolicy": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "profileId": { "$ref": "#/$defs/stableId" },
        "allowAnonymous": { "type": "boolean" }
      },
      "required": ["profileId", "allowAnonymous"]
    },
    "exposureLimits": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "maxBodyBytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "maxResponseBytes": { "type": "integer", "minimum": 1, "maximum": 67108864 },
        "requestsPerMinute": { "type": "integer", "minimum": 1, "maximum": 1000000 },
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 300000 }
      },
      "required": ["maxBodyBytes", "maxResponseBytes", "requestsPerMinute", "timeoutMs"]
    },
    "exposureTarget": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "logicalService": { "$ref": "#/$defs/stableId" },
        "routingDomain": { "$ref": "#/$defs/stableId" }
      },
      "required": ["logicalService", "routingDomain"]
    },
    "exposure": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": "v1" },
        "id": { "type": "string", "pattern": "^exp_[a-z2-7]{20}$" },
        "revision": { "type": "integer", "minimum": 1 },
        "routeKey": { "$ref": "#/$defs/routeKey" },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 160 },
        "tenantId": { "$ref": "#/$defs/stableId" },
        "portalId": { "$ref": "#/$defs/stableId" },
        "hosts": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "$ref": "#/$defs/host" } },
        "contract": { "$ref": "#/$defs/contractReference" },
        "authentication": { "$ref": "#/$defs/authenticationPolicy" },
        "requiredPermissions": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/governedId" } },
        "limits": { "$ref": "#/$defs/exposureLimits" },
        "target": { "$ref": "#/$defs/exposureTarget" }
      },
      "required": ["schemaVersion", "id", "revision", "routeKey", "displayName", "tenantId", "hosts", "contract", "authentication", "requiredPermissions", "limits", "target"]
    },
    "resolvedExposure": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "exposure": { "$ref": "#/$defs/exposure" },
        "contract": { "$ref": "#/$defs/apiContractContribution" }
      },
      "required": ["exposure", "contract"]
    },
    "exposureCatalog": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": "v1" },
        "generation": { "type": "integer", "minimum": 1 },
        "exposures": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/resolvedExposure" } },
        "dataPlaneExposures": { "type": "array", "maxItems": 10000, "items": { "$ref": "#/$defs/dataPlaneExposure" } }
      },
      "required": ["schemaVersion", "generation", "exposures", "dataPlaneExposures"]
    },
    "dataPlaneExposure": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": "v1" },
        "id": { "type": "string", "pattern": "^dpx_[a-z2-7]{20}$" },
        "revision": { "type": "integer", "minimum": 1 },
        "routeKey": { "$ref": "#/$defs/routeKey" },
        "tenantId": { "$ref": "#/$defs/stableId" },
        "hosts": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "$ref": "#/$defs/host" } },
        "service": { "$ref": "#/$defs/dataPlaneServiceReference" },
        "dataPlaneServiceId": { "$ref": "#/$defs/localId" },
        "allowedModes": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/dataPlaneMode" } },
        "allowedEndpointOrigins": { "type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": { "type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2048 } },
        "tlsIdentityPrefix": { "type": "string", "pattern": "^spiffe://", "maxLength": 512 },
        "authentication": { "$ref": "#/$defs/authenticationPolicy" },
        "requiredPermissions": { "type": "array", "maxItems": 16, "uniqueItems": true, "items": { "$ref": "#/$defs/governedId" } },
        "maxObjectBytes": { "type": "integer", "minimum": 1, "maximum": 1099511627776 }
      },
      "required": ["schemaVersion", "id", "revision", "routeKey", "tenantId", "hosts", "service", "dataPlaneServiceId", "allowedModes", "allowedEndpointOrigins", "tlsIdentityPrefix", "authentication", "requiredPermissions", "maxObjectBytes"]
    },
    "endpointLease": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": "v1" },
        "leaseId": { "type": "string", "pattern": "^lease_[A-Za-z0-9_-]{32,128}$" },
        "dataPlaneExposureId": { "type": "string", "pattern": "^dpx_[a-z2-7]{20}$" },
        "instanceId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,159}$" },
        "endpoint": { "type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2048 },
        "tlsIdentity": { "type": "string", "pattern": "^spiffe://", "maxLength": 512 },
        "modes": { "type": "array", "minItems": 1, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/dataPlaneMode" } },
        "issuedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["schemaVersion", "leaseId", "dataPlaneExposureId", "instanceId", "endpoint", "tlsIdentity", "modes", "issuedAt", "expiresAt"]
    },
    "gatewayInvocation": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "schemaVersion": { "const": "v1" },
        "routeId": { "$ref": "#/$defs/governedId" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "pathParams": { "type": "object", "maxProperties": 32, "propertyNames": { "pattern": "^[a-z][A-Za-z0-9]*$" }, "additionalProperties": { "type": "string", "maxLength": 2048 } },
        "query": { "type": "object", "maxProperties": 64, "propertyNames": { "pattern": "^[a-z][A-Za-z0-9._-]*$" }, "additionalProperties": { "type": "array", "maxItems": 32, "items": { "type": "string", "maxLength": 4096 } } },
        "body": {}
      },
      "required": ["schemaVersion", "routeId", "method", "pathParams", "query", "body"]
    }
  }
}
