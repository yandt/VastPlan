{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json",
  "title": "VastPlan Common Identifiers v1",
  "$defs": {
    "pluginId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$",
      "maxLength": 160
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "versionRange": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "channel": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "entryPath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "pattern": "^[^/].*$" },
        { "not": { "pattern": "(^|/)\\.\\.(/|$)" } }
      ]
    },
    "managedCredentialRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "handle": { "type": "string", "pattern": "^credential://managed/[A-Za-z0-9._~-]+$", "maxLength": 256 },
        "scope": { "type": "string", "enum": ["tenant", "service"] },
        "owner": { "$ref": "#/$defs/pluginId" },
        "purpose": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$", "maxLength": 160 },
        "version": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1, "maxLength": 160 }
      },
      "required": ["handle", "scope", "owner", "purpose", "version"]
    }
  }
}
