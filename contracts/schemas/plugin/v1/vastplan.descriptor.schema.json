{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/plugin/v1/vastplan.descriptor.schema.json",
  "title": "VastPlan Runtime Contribution Descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["extensionPoint", "descriptor"],
  "properties": {
    "extensionPoint": {
      "enum": [
        "tool.package",
        "agent",
        "api.route",
        "permission.checker",
        "event.sink",
        "hook",
        "runner.capability",
        "authentication.provider",
        "configuration.controller", "configuration.resource-controller", "configuration.scoped-resolver"
      ]
    },
    "descriptor": { "type": "object" }
  },
  "$defs": {
    "title": { "type": "string", "minLength": 1, "maxLength": 160 },
    "serviceRole": { "enum": ["backend", "workspace", "rs"] },
    "capabilityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extensionPoint", "capability"],
      "properties": {
        "extensionPoint": { "type": "string", "minLength": 1, "maxLength": 160 },
        "capability": { "type": "string", "minLength": 1, "maxLength": 160 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "operation": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "subcommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "paramsSchema": { "type": "object" },
        "resultSchema": { "type": "object" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "extensionPoint": { "const": "tool.package" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "$ref": "#/$defs/serviceRole" },
              "subcommands": {
                "type": "array",
                "items": { "$ref": "#/$defs/subcommand" },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "agent" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["systemPrompt"],
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "$ref": "#/$defs/serviceRole" },
              "role": { "type": "string", "minLength": 1, "maxLength": 160 },
              "systemPrompt": { "type": "string", "minLength": 1 },
              "tools": {
                "type": "array",
                "items": { "$ref": "#/$defs/capabilityRef" },
                "uniqueItems": true
              },
              "model": { "type": "string", "minLength": 1, "maxLength": 160 },
              "defaultScene": { "type": "string", "minLength": 1, "maxLength": 160 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "api.route" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["method", "path", "auth", "service_role"],
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "$ref": "#/$defs/serviceRole" },
              "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "path": { "type": "string", "pattern": "^/", "minLength": 1, "maxLength": 512 },
              "auth": { "enum": ["session", "service", "public"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "permission.checker" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "$ref": "#/$defs/serviceRole" },
              "applies": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "caller": { "type": "string" },
                  "scene": { "type": "string" },
                  "target": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "event.sink" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "$ref": "#/$defs/serviceRole" },
              "subscribe": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "hook" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["point", "phase"],
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "$ref": "#/$defs/serviceRole" },
              "point": { "enum": ["invoke"] },
              "phase": { "enum": ["before", "after"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "runner.capability" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["service_role", "kind"],
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "service_role": { "const": "rs" },
              "kind": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
                "maxLength": 160
              },
              "params": { "type": "object" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "authentication.provider" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["protocol", "purposes", "methods", "subjectNamespace", "requiredCapabilities"],
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "protocol": { "const": "authentication.method.v1" },
              "purposes": {
                "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true,
                "items": { "enum": ["portal-login", "mobile-token", "runner-token", "token-verification", "directory", "provisioning"] }
              },
              "methods": {
                "type": "array", "minItems": 1, "maxItems": 32,
                "items": {
                  "type": "object", "additionalProperties": false, "required": ["id", "kind", "interaction"],
                  "properties": {
                    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,63}$" },
                    "kind": { "enum": ["password", "one-time-code", "redirect", "passkey"] },
                    "interaction": { "enum": ["form", "redirect", "native"] }
                  }
                }
              },
              "subjectNamespace": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$", "maxLength": 160 },
              "requiredCapabilities": {
                "type": "array", "maxItems": 32, "uniqueItems": true,
                "items": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$", "maxLength": 160 }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "configuration.controller" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["protocol"],
            "properties": {
              "protocol": { "const": "configuration.v1" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "configuration.resource-controller" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object",
            "additionalProperties": false,
            "required": ["protocol"],
            "properties": {
              "protocol": { "const": "configuration.resource.v1" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "extensionPoint": { "const": "configuration.scoped-resolver" } } },
      "then": {
        "properties": {
          "descriptor": {
            "type": "object", "additionalProperties": false,
            "required": ["protocol"],
            "properties": {
              "title": { "$ref": "#/$defs/title" },
              "protocol": { "const": "configuration.scoped.v1" }
            }
          }
        }
      }
    }
  ]
}
