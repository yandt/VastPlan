{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/plugin/v1/vastplan.artifact-lock.schema.json",
  "title": "VastPlan Artifact Lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repositoryRevision", "target", "kernelVersion", "roots", "packages", "digest"],
  "properties": {
    "schemaVersion": { "const": "v1" },
    "repositoryRevision": { "type": "integer", "minimum": 1 },
    "target": { "enum": ["backend", "frontend", "runner", "mobile"] },
    "kernelVersion": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
    "platform": { "type": "string", "pattern": "^[a-z0-9]+/[a-z0-9_]+$", "maxLength": 40 },
    "roots": {
      "type": "array", "minItems": 1, "maxItems": 256,
      "items": { "$ref": "#/$defs/requirement" }
    },
    "packages": {
      "type": "array", "minItems": 1, "maxItems": 1024,
      "items": { "$ref": "#/$defs/package" }
    },
    "digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "requirement": {
      "type": "object", "additionalProperties": false, "required": ["pluginId", "constraint"],
      "properties": {
        "pluginId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "constraint": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" }
      }
    },
    "ref": {
      "type": "object", "additionalProperties": false, "required": ["pluginId", "version", "channel"],
      "properties": {
        "pluginId": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel" }
      }
    },
    "package": {
      "type": "object", "additionalProperties": false,
      "required": ["ref", "sha256", "size", "publisher", "keyId", "repositoryRevision"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 1 },
        "publisher": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,79}$" },
        "keyId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "repositoryRevision": { "type": "integer", "minimum": 1 },
        "dependencies": {
          "type": "object",
          "propertyNames": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
          "additionalProperties": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" }
        }
      }
    }
  }
}
