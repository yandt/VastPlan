{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/plugin/v1/vastplan.plugin.schema.json",
  "title": "VastPlan Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "publisher", "engines", "activation", "entry", "contributes"],
  "properties": {
    "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
    "name": { "type": "string", "minLength": 1, "maxLength": 160 },
    "description": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
    "publisher": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel" },
    "license": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 .()+-]*$"
    },
    "licenseFile": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" },
    "noticeFile": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" },
    "engines": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "backend": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" },
        "frontend": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" },
        "runner": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" },
        "mobile": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kernelServices": { "$ref": "#/$defs/stringList" },
        "credentials": { "$ref": "#/$defs/stringList" },
        "resources": { "$ref": "#/$defs/stringList" }
      }
    },
    "contextAccess": { "$ref": "#/$defs/contextAccess" },
    "runtime": { "$ref": "#/$defs/runtimePolicy" },
    "execution": { "$ref": "#/$defs/executionPolicy" },
    "activation": { "$ref": "#/$defs/stringList" },
    "dependencies": {
      "type": "object",
      "propertyNames": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
      "additionalProperties": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" }
    },
    "state": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "backend": { "$ref": "#/$defs/backendState" }
      }
    },
    "entry": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "backend": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" },
        "frontend": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" },
        "runner": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" },
        "mobile": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" }
      }
    },
    "contributes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "backend": { "$ref": "#/$defs/backendContributes" },
        "frontend": { "$ref": "#/$defs/frontendContributes" },
        "runner": { "$ref": "#/$defs/runnerContributes" },
        "mobile": { "$ref": "#/$defs/mobileContributes" }
      }
    }
  },
  "allOf": [
    { "if": { "required": ["license"] }, "then": { "required": ["licenseFile"] } },
    { "if": { "required": ["licenseFile"] }, "then": { "required": ["license"] } },
    { "if": { "required": ["noticeFile"] }, "then": { "required": ["license"] } }
  ],
  "$defs": {
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "contextField": {
      "enum": [
        "scope.tenant", "scope.project", "caller", "scene", "subject.id", "subject.profile",
        "authorization.roles", "authorization.admin", "trace", "request.deadline",
        "request.idempotency", "grant.credentials", "baggage", "propagation.callPath"
      ]
    },
    "contextAccess": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "array", "items": { "$ref": "#/$defs/contextField" }, "uniqueItems": true },
        "optional": { "type": "array", "items": { "$ref": "#/$defs/contextField" }, "uniqueItems": true },
        "baggage": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*(?:\\*)?$", "maxLength": 160 },
          "uniqueItems": true
        }
      }
    },
    "executionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "backend": { "$ref": "#/$defs/backendExecution" }
      }
    },
    "backendExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["driver"],
      "properties": {
        "driver": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$", "maxLength": 80 },
        "args": { "type": "array", "items": { "type": "string", "maxLength": 4096 }, "maxItems": 64 },
        "requirements": {
          "type": "object",
          "propertyNames": { "pattern": "^[a-z][a-z0-9.-]{0,79}$" },
          "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+/[a-z0-9_]+$", "maxLength": 40 },
          "uniqueItems": true,
          "maxItems": 32
        },
        "minimumIsolation": {
          "enum": ["trusted-process", "process-sandbox", "container", "wasm"]
        },
        "features": { "$ref": "#/$defs/stringList" },
        "dynamicGo": { "$ref": "#/$defs/dynamicGoExecution" }
      }
    },
    "dynamicGoExecution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry", "abi"],
      "properties": {
        "entry": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/entryPath" },
        "abi": { "const": "vastplan.dynamic-go.v1" },
        "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "required": { "type": "boolean" }
      }
    },
    "runtimePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["instancePolicy", "stateModel", "visibility", "routing"],
      "properties": {
        "instancePolicy": { "enum": ["per-kernel", "active-active", "leader", "partitioned"] },
        "stateModel": { "enum": ["local-ephemeral", "external-shared", "leader-owned", "partition-owned"] },
        "visibility": { "enum": ["local", "service", "cluster", "global"] },
        "routing": { "enum": ["direct", "queue", "leader", "shard"] },
        "routingDomain": { "type": "string", "minLength": 1, "maxLength": 160 },
        "provides": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/runtimeCapabilityPolicy" }
        },
        "requires": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/runtimeRequirement" }
        }
      }
    },
    "runtimeCapabilityPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extensionPoint", "capability"],
      "properties": {
        "extensionPoint": { "type": "string", "minLength": 1, "maxLength": 160 },
        "capability": { "type": "string", "minLength": 1, "maxLength": 160 },
        "visibility": { "enum": ["local", "service", "cluster", "global"] },
        "routing": { "enum": ["direct", "queue", "leader", "shard"] },
        "routingDomain": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "runtimeRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "scope", "kind", "ready", "failurePolicy"],
      "properties": {
        "capability": { "type": "string", "minLength": 1, "maxLength": 160 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "scope": { "enum": ["same-node", "same-kernel", "remote"] },
        "kind": { "enum": ["strong", "soft", "lazy", "data"] },
        "ready": { "enum": ["readiness", "health"] },
        "failurePolicy": { "enum": ["fail", "degrade", "retry"] },
        "logicalService": { "type": "string", "minLength": 1, "maxLength": 160 },
        "routingDomain": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "stateIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "formatVersion"],
      "properties": {
        "format": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$",
          "maxLength": 160
        },
        "formatVersion": { "type": "integer", "minimum": 1, "maximum": 2147483647 }
      }
    },
    "backendState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "formatVersion"],
      "properties": {
        "format": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$",
          "maxLength": 160
        },
        "formatVersion": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
        "migration": {
          "type": "object",
          "additionalProperties": false,
          "required": ["protocol", "from"],
          "properties": {
            "protocol": { "const": "lifecycle.v1" },
            "from": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "$ref": "#/$defs/stateIdentity" }
            }
          }
        }
      }
    },
    "baseContribution": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "service_role": { "enum": ["backend", "workspace", "rs"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "priority": { "type": "integer", "minimum": -1000000, "maximum": 1000000 }
      }
    },
    "capabilityRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["extensionPoint", "capability"],
      "properties": {
        "extensionPoint": { "type": "string", "minLength": 1, "maxLength": 160 },
        "capability": { "type": "string", "minLength": 1, "maxLength": 160 },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "operation": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "tool": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["service_role"],
          "properties": {
            "id": true, "service_role": true, "title": true, "priority": true,
            "subcommands": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "description"],
                  "properties": {
                    "name": { "type": "string", "minLength": 1 },
                    "description": { "type": "string", "minLength": 1 },
                    "paramsSchema": { "type": "object" },
                    "resultSchema": { "type": "object" }
                  }
              }
            }
          }
        }
      ]
    },
    "agent": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["service_role", "systemPrompt"],
          "properties": {
            "id": true, "service_role": true, "title": true, "priority": true,
            "role": { "type": "string", "minLength": 1, "maxLength": 160 },
            "systemPrompt": { "type": "string", "minLength": 1 },
            "tools": {
              "type": "array",
              "items": { "$ref": "#/$defs/capabilityRef" },
              "uniqueItems": true
            },
            "model": { "type": "string", "minLength": 1, "maxLength": 160 },
            "defaultScene": { "type": "string", "minLength": 1, "maxLength": 160 }
          }
        }
      ]
    },
    "apiRoute": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["service_role", "method", "path", "auth"],
          "properties": {
            "id": true, "service_role": true, "title": true, "priority": true,
            "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
            "path": { "type": "string", "pattern": "^/", "minLength": 1, "maxLength": 512 },
            "auth": { "enum": ["session", "service", "public"] }
          }
        }
      ]
    },
    "permissionChecker": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object", "additionalProperties": false,
          "required": ["service_role"],
          "properties": {
            "id": true, "service_role": true, "title": true, "priority": true,
            "applies": {
              "type": "object", "additionalProperties": false,
              "properties": { "caller": { "type": "string" }, "scene": { "type": "string" }, "target": { "type": "string" } }
            }
          }
        }
      ]
    },
    "eventSink": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object", "additionalProperties": false,
          "required": ["service_role"],
          "properties": {
            "id": true, "service_role": true, "title": true, "priority": true,
            "subscribe": { "$ref": "#/$defs/stringList" }
          }
        }
      ]
    },
    "hook": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object", "additionalProperties": false,
          "required": ["service_role", "point", "phase"],
          "properties": {
            "id": true, "service_role": true, "title": true, "priority": true,
            "point": { "enum": ["invoke"] },
            "phase": { "enum": ["before", "after"] }
          }
        }
      ]
    },
    "runnerCapability": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["service_role", "kind"],
          "properties": {
            "id": true, "title": true, "priority": true,
            "service_role": { "const": "rs" },
            "kind": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "maxLength": 160
            },
            "params": { "type": "object" }
          }
        }
      ]
    },
    "genericContribution": {
      "allOf": [
        { "$ref": "#/$defs/baseContribution" },
        { "type": "object" }
      ]
    },
    "backendContributes": {
      "type": "object", "minProperties": 1, "additionalProperties": false,
      "properties": {
        "tools": { "type": "array", "items": { "$ref": "#/$defs/tool" } },
        "agents": { "type": "array", "items": { "$ref": "#/$defs/agent" } },
        "apiRoutes": { "type": "array", "items": { "$ref": "#/$defs/apiRoute" } },
        "permissionCheckers": { "type": "array", "items": { "$ref": "#/$defs/permissionChecker" } },
        "eventSinks": { "type": "array", "items": { "$ref": "#/$defs/eventSink" } },
        "hooks": { "type": "array", "items": { "$ref": "#/$defs/hook" } },
        "runnerCapabilities": { "type": "array", "items": { "$ref": "#/$defs/runnerCapability" } }
      }
    },
    "frontendContributes": {
      "type": "object", "minProperties": 1, "additionalProperties": false,
      "properties": {
        "views": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "editors": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "commands": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "menus": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "settings": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "designSystems": { "type": "array", "items": { "$ref": "#/$defs/designSystemContribution" } },
        "shellCompositions": { "type": "array", "items": { "$ref": "#/$defs/shellFoundationContribution" } },
        "shellLayouts": { "type": "array", "items": { "$ref": "#/$defs/shellFoundationContribution" } }
      }
    },
    "designSystemContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uiContract", "framework", "capabilities"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "priority": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "uiContract": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" },
        "framework": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$", "maxLength": 80 },
        "capabilities": {
          "type": "array",
          "minItems": 7,
          "uniqueItems": true,
          "items": { "enum": ["layout", "menu", "overlay", "form", "data", "feedback", "theme", "navigation"] },
          "allOf": [
            { "contains": { "const": "layout" } },
            { "contains": { "const": "menu" } },
            { "contains": { "const": "overlay" } },
            { "contains": { "const": "form" } },
            { "contains": { "const": "data" } },
            { "contains": { "const": "feedback" } },
            { "contains": { "const": "theme" } }
          ]
        }
      }
    },
    "shellFoundationContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "uiContract"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "priority": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "uiContract": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" }
      }
    },
    "runnerContributes": {
      "type": "object", "minProperties": 1, "additionalProperties": false,
      "properties": {
        "scripts": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "workflows": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "interactions": { "type": "array", "items": { "$ref": "#/$defs/runnerInteractionContribution" } },
        "runtimeRequirements": { "$ref": "#/$defs/stringList" }
      }
    },
    "runnerInteractionContribution": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "interactionContract", "kinds", "allowedSurfaces"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 160 },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "priority": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "interactionContract": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" },
        "kinds": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": { "enum": ["confirm", "form", "approval", "notification", "progress"] }
        },
        "allowedSurfaces": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": { "enum": ["frontend", "mobile", "runner.local"] }
        },
        "experience": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "mobileContributes": {
      "type": "object", "minProperties": 1, "additionalProperties": false,
      "properties": {
        "views": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "approvals": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "triggers": { "type": "array", "items": { "$ref": "#/$defs/genericContribution" } },
        "uiAdapters": { "type": "array", "items": { "$ref": "#/$defs/mobileUIAdapterContribution" } }
      }
    },
    "mobileUIAdapterContribution": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "uiContract", "framework", "capabilities"],
      "properties": {
        "id": { "const": "mobile.ui-adapter" },
        "title": { "type": "string", "minLength": 1, "maxLength": 160 },
        "priority": { "type": "integer", "minimum": -1000000, "maximum": 1000000 },
        "uiContract": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/versionRange" },
        "framework": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$", "maxLength": 80 },
        "capabilities": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": { "enum": ["layout", "menu", "overlay", "form", "data", "feedback", "theme", "approval", "navigation"] }
        }
      }
    }
  }
}
