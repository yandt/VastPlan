{
  "name": "vastplan-workspace",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build:frontend": "./engineering/tools/build-frontend.sh",
    "build:portal-host": "pnpm --filter @vastplan/portal-host build",
    "build:frontend:plugins": "node engineering/tools/build-frontend-plugins.mjs",
    "typecheck": "pnpm -r --if-present typecheck",
    "test:frontend": "pnpm -r --if-present test && node --test engineering/tools/frontend-module-graph.test.mjs"
  },
  "devDependencies": {
    "@fontsource/noto-sans": "^5.3.0",
    "@fontsource/noto-sans-sc": "^5.3.0",
    "esbuild": "0.28.1"
  }
}
