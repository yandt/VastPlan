{
  "version": 1,
  "revision": 1,
  "metadata": {
    "name": "local-development"
  },
  "units": [
    {
      "id": "backend-main",
      "kind": "service",
      "plugins": [
        {
          "id": "cn.vastplan.demo-permission",
          "version": "0.2.0",
          "channel": "stable"
        },
        {
          "id": "cn.vastplan.hello-world",
          "version": "0.2.0",
          "channel": "stable"
        }
      ],
      "config": {
        "plugins": {
          "cn.vastplan.hello-world": {
            "greetingTemplate": "你好，{{name}}！我是 VastPlan 租户级插件。"
          }
        }
      },
      "enabled": true,
      "service_role": "backend",
      "logical_service": "local.hello",
      "instance_policy": "active-active",
      "state_model": "external-shared",
      "visibility": "cluster",
      "routing": "queue",
      "routing_domain": "application",
      "replicas": 1,
      "placement": {
        "nodeSelector": {
          "environment": "local"
        }
      }
    }
  ]
}
