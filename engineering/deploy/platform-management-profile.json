{
  "version": 1,
  "revision": 1,
  "id": "local-platform-management",
  "target": { "kernel": "backend" },
  "serviceClasses": ["application.backend"],
  "attachments": [],
  "services": [
    {
      "id": "platform-settings",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.settings",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "platform.settings.stateFile": "__VASTPLAN_DEV_ROOT__/state/settings.json"
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.bootstrap-policy", "version": "0.1.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.3.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.configuration.global-settings", "version": "0.2.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-artifacts",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.artifacts.repository",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": [
          "VASTPLAN_ARTIFACT_LISTEN_ADDR",
          "VASTPLAN_ARTIFACT_REPOSITORY",
          "VASTPLAN_ARTIFACT_TRUST",
          "VASTPLAN_ARTIFACT_TLS_CERT",
          "VASTPLAN_ARTIFACT_TLS_KEY",
          "VASTPLAN_ARTIFACT_READ_TOKEN",
          "VASTPLAN_ARTIFACT_PUBLISH_TOKEN"
        ]
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.3.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.artifacts.repository", "version": "0.2.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-credentials",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.credentials",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": [
          "VASTPLAN_CREDENTIALS_STATE_FILE",
          "VASTPLAN_VAULT_ADDR",
          "VASTPLAN_VAULT_TRANSIT_KEY",
          "VASTPLAN_VAULT_TOKEN_FILE"
        ]
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.3.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.security.credentials", "version": "0.2.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-database",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.database",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": ["VASTPLAN_DATABASE_CONNECTIONS_STATE_FILE"]
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.3.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.data.relational.connection-manager", "version": "0.2.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-deployment",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.deployment",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": ["VASTPLAN_DEPLOYMENT_MANAGER_STATE_FILE"]
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.3.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.infrastructure.deployment-manager", "version": "0.3.0", "channel": "stable" }
      ]
    }
  ]
}
