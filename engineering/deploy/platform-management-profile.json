            "gatewayCatalogFile": "__VASTPLAN_DEV_STATE__/api-exposure-gateway.json",
            "contractCatalogFile": "__VASTPLAN_DEV_STATE__/api-contract-catalog.json"
          }
        },
        "environment_allowlist": {
          "cn.vastplan.foundation.security.authorization-enforcer": ["VASTPLAN_AUTHORIZATION_PERMISSION_CATALOG", "VASTPLAN_AUTHORIZATION_POLICY_SNAPSHOT", "VASTPLAN_AUTHORIZATION_POLICY_TRUST", "VASTPLAN_AUTHORIZATION_POLICY_AUDIENCE", "VASTPLAN_AUTHORIZATION_DIRECTORY_GROUPS"]
