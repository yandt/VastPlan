      "id": "platform-settings",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.settings",
      "instance_policy": "active-active",
      "state_model": "external-shared",
      "visibility": "cluster",
      "routing": "queue",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": {
          "cn.vastplan.foundation.security.authorization-enforcer": ["VASTPLAN_AUTHORIZATION_PERMISSION_CATALOG", "VASTPLAN_AUTHORIZATION_POLICY_SNAPSHOT", "VASTPLAN_AUTHORIZATION_POLICY_TRUST", "VASTPLAN_AUTHORIZATION_POLICY_AUDIENCE", "VASTPLAN_AUTHORIZATION_DIRECTORY_GROUPS"]
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.authorization-enforcer", "version": "0.1.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.security.bootstrap-policy", "version": "0.1.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.29.0", "channel": "stable" },
