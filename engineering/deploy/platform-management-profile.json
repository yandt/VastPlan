{
  "version": 1,
  "revision": 4,
  "id": "local-platform-management",
  "target": { "kernel": "backend" },
  "serviceClasses": ["application.backend"],
  "attachments": [],
  "services": [
    {
      "id": "platform-settings",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.settings",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "plugins": {
          "cn.vastplan.platform.configuration.global-settings": {
            "platform.settings.stateFile": "__VASTPLAN_DEV_STATE__/settings.json"
          }
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.bootstrap-policy", "version": "0.1.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.17.1", "channel": "stable" },
        { "id": "cn.vastplan.platform.configuration.global-settings", "version": "0.3.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-artifacts",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.artifacts.repository",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "plugins": {
          "cn.vastplan.platform.artifacts.storage.file": {
            "volumeId": "repository.primary"
          },
          "cn.vastplan.platform.artifacts.repository": {
            "listen": "__VASTPLAN_ARTIFACT_LISTEN__",
            "storageProvider": "platform.artifacts.storage.file",
            "volumeId": "repository.primary",
            "quota": {
              "maxArtifacts": 10000,
              "maxBytes": 10737418240,
              "rules": [
                { "id": "testing-channel", "channel": "testing", "maxArtifacts": 5000, "maxBytes": 5368709120 }
              ]
            }
          }
        },
        "environment_allowlist": {
          "cn.vastplan.platform.artifacts.storage.file": [
            "VASTPLAN_ARTIFACT_FILE_PROVIDER_ROOT"
          ],
          "cn.vastplan.platform.artifacts.repository": [
            "VASTPLAN_ARTIFACT_REPOSITORY",
            "VASTPLAN_ARTIFACT_TRUST",
            "VASTPLAN_ARTIFACT_TLS_CERT",
            "VASTPLAN_ARTIFACT_TLS_KEY",
            "VASTPLAN_ARTIFACT_READ_TOKEN",
            "VASTPLAN_ARTIFACT_PUBLISH_TOKEN",
            "VASTPLAN_ARTIFACT_BUNDLE_TOKEN",
            "VASTPLAN_ARTIFACT_MIGRATION_STATE"
          ]
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.17.1", "channel": "stable" },
        { "id": "cn.vastplan.platform.artifacts.storage.file", "version": "0.2.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.artifacts.repository", "version": "0.13.1", "channel": "stable" }
      ]
    },
    {
      "id": "platform-credentials",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.credentials",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": {
          "cn.vastplan.platform.security.credentials": [
            "VASTPLAN_CREDENTIALS_STATE_FILE",
            "VASTPLAN_VAULT_ADDR",
            "VASTPLAN_VAULT_TRANSIT_KEY",
            "VASTPLAN_VAULT_TOKEN_FILE"
          ]
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.17.1", "channel": "stable" },
        { "id": "cn.vastplan.platform.security.credentials", "version": "0.5.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-database",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.database",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": {
          "cn.vastplan.platform.data.relational.connection-manager": ["VASTPLAN_DATABASE_CONNECTIONS_STATE_FILE"]
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.17.1", "channel": "stable" },
        { "id": "cn.vastplan.platform.data.relational.connection-manager", "version": "0.5.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-database-runtime",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "foundation.data.relational.runtime",
      "instance_policy": "active-active",
      "state_model": "external-shared",
      "visibility": "cluster",
      "routing": "queue",
      "routing_domain": "platform",
      "replicas": 2,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "plugins": {
          "cn.vastplan.foundation.data.relational.runtime": { "allowInsecureTLS": false, "maxTransactions": 4096 }
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.17.1", "channel": "stable" },
        { "id": "cn.vastplan.foundation.data.relational.runtime", "version": "0.7.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-deployment",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.deployment",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "environment_allowlist": {
          "cn.vastplan.platform.infrastructure.deployment-manager": ["VASTPLAN_DEPLOYMENT_MANAGER_STATE_FILE"]
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.platform-admin-access-policy", "version": "0.17.1", "channel": "stable" },
        { "id": "cn.vastplan.platform.infrastructure.deployment-manager", "version": "0.7.1", "channel": "stable" }
      ]
    },
    {
      "id": "platform-portal-composer",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.portal-composer",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "plugins": {
          "cn.vastplan.platform.configuration.portal-composer": {
            "platform.portal-composer.stateFile": "__VASTPLAN_DEV_STATE__/portal-composer.json",
            "platform.portal-composer.platformCatalog": "__VASTPLAN_PORTAL_PLATFORM_CATALOG__"
          }
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.portal-access-policy", "version": "0.2.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.configuration.portal-composer", "version": "1.3.0", "channel": "stable" }
      ]
    },
    {
      "id": "platform-interaction-broker",
      "kind": "service",
      "enabled": true,
      "service_role": "backend",
      "logical_service": "platform.interaction-broker",
      "instance_policy": "leader",
      "state_model": "leader-owned",
      "visibility": "cluster",
      "routing": "leader",
      "routing_domain": "platform",
      "replicas": 1,
      "placement": { "nodeSelector": { "environment": "local-platform" } },
      "config": {
        "plugins": {
          "cn.vastplan.platform.interaction.broker": {
            "platform.interaction-broker.stateFile": "__VASTPLAN_DEV_STATE__/interaction-broker.json"
          }
        }
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.security.interaction-access-policy", "version": "0.1.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.interaction.broker", "version": "0.1.0", "channel": "stable" }
      ]
    }
  ]
}
