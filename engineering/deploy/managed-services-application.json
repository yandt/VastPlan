{
  "version": 1,
  "revision": 1,
  "id": "managed-services",
  "target": {
    "kernel": "backend"
  },
  "metadata": {
    "name": "managed-services",
    "tenant": "local"
  },
  "units": [
    {
      "serviceClass": "application.backend",
      "spec": {
        "id": "hello-service",
        "kind": "service",
        "enabled": true,
        "service_role": "backend",
        "logical_service": "managed.hello",
        "instance_policy": "active-active",
        "state_model": "external-shared",
        "visibility": "cluster",
        "routing": "queue",
        "routing_domain": "application",
        "replicas": 1,
        "placement": {
          "nodeSelector": {
            "environment": "local-managed"
          }
        },
        "plugins": [
          {
            "id": "cn.vastplan.hello-world",
            "version": "0.2.0",
            "channel": "stable"
          }
        ],
        "config": {
          "plugins": {
            "cn.vastplan.hello-world": {
              "greetingTemplate": "你好，{{name}}！我是 VastPlan 租户级插件。"
            }
          }
        }
      }
    }
  ]
}
