        { "id": "cn.vastplan.foundation.frontend.render.adapter.mui", "version": "1.3.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.structure.shell", "version": "1.0.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.structure.layout.standard", "version": "1.1.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.structure.layout.top-navigation", "version": "1.1.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.workflow.workbench", "version": "1.4.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.configuration.portal-composer", "version": "1.3.0", "channel": "stable" },
