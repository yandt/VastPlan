        "version": "1.0.0",
        "channel": "stable",
        "uiContract": "^4.0.0",
        "config": {
          "defaultTemplate": "standard",
          "allowedTemplates": ["standard", "top-navigation"],
          "userSelectable": true,
          "templateOptions": {
            "standard": { "pageBodyWidth": "fluid" },
            "top-navigation": { "pageBodyWidth": "fluid" }
