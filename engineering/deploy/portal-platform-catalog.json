{
  "version": 1,
  "revision": 1,
  "id": "local-portal-platform",
  "profiles": [
    {
      "version": 1,
      "revision": 1,
      "id": "portal-default",
      "target": { "kernel": "frontend" },
      "renderAdapter": {
        "id": "cn.vastplan.foundation.frontend.render.adapter.arco",
        "version": "1.0.0",
        "channel": "stable",
        "uiContract": "^3.0.0"
      },
      "structureComposition": {
        "id": "cn.vastplan.foundation.frontend.structure.composition.standard",
        "version": "1.0.0",
        "channel": "stable",
        "uiContract": "^3.0.0"
      },
      "structureLayout": {
        "id": "cn.vastplan.foundation.frontend.structure.layout.standard",
        "version": "1.0.0",
        "channel": "stable",
        "uiContract": "^3.0.0",
        "config": {
          "navigation": "rail",
          "logoPlacement": "navigation",
          "settingsPlacement": "navigation-bottom",
          "pageBodyWidth": "fluid"
        }
      },
      "workbench": {
        "id": "cn.vastplan.foundation.frontend.workflow.workbench",
        "version": "1.0.0",
        "channel": "stable",
        "uiContract": "^3.0.0"
      },
      "plugins": [
        { "id": "cn.vastplan.foundation.frontend.render.adapter.arco", "version": "1.0.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.structure.composition.standard", "version": "1.0.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.structure.layout.standard", "version": "1.0.0", "channel": "stable" },
        { "id": "cn.vastplan.foundation.frontend.workflow.workbench", "version": "1.0.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.configuration.portal-composer", "version": "1.0.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.configuration.global-settings", "version": "0.2.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.security.credentials", "version": "0.2.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.data.relational.connection-manager", "version": "0.2.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.artifacts.repository", "version": "0.2.0", "channel": "stable" },
        { "id": "cn.vastplan.platform.infrastructure.deployment-manager", "version": "0.3.0", "channel": "stable" }
      ],
      "security": { "firstPartyOnly": true, "requireIntegrity": true }
    }
  ],
  "bindings": [
    {
      "tenantId": "local",
      "portalId": "operations",
      "platformProfile": {
        "id": "portal-default",
        "revision": 1,
        "digest": "b1658a8afc1b9e3bb25f1e4ab1b6bdeccf777c98d49ed97d53af395ce9a7741f"
      },
      "services": [
        {
          "id": "settings",
          "label": "全局设置服务",
          "logicalService": "platform.settings",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.settings", "read": ["list"], "write": ["put", "delete"] }
          ]
        },
        {
          "id": "credentials",
          "label": "凭证管理服务",
          "logicalService": "platform.credentials",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.credentials", "read": ["list"], "write": ["put", "rotate", "revoke"] }
          ]
        },
        {
          "id": "database",
          "label": "数据库服务",
          "logicalService": "platform.database",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.database", "read": ["list"], "write": ["define", "remove", "probe"] }
          ]
        },
        {
          "id": "artifacts",
          "label": "制品仓库服务",
          "logicalService": "platform.artifacts.repository",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.artifacts.repository", "read": ["status"] }
          ]
        },
        {
          "id": "deployment",
          "label": "部署管理服务",
          "logicalService": "platform.deployment",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.deployment", "read": ["listNodes", "listBootstrapJobs", "listDeploymentTargets", "listServiceRevisions", "listServiceRevisionAudit"], "write": ["putNode", "createBootstrap", "approveBootstrap", "createServiceDraft", "updateServiceDraft", "submitServiceDraft", "approveServiceRevision", "publishServiceRevision", "rollbackServiceRevision"] }
          ]
        }
      ]
    }
  ]
}
