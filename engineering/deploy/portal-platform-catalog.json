  ],
  "bindings": [
    {
      "tenantId": "local",
      "portalId": "operations",
      "platformProfile": {
        "id": "portal-default",
        "revision": 1,
        "digest": "e79129723275df151d2bacc9699d4905a106e7d5a32031a76f0bcb328726b52c"
      },
      "services": [
        {
          "id": "settings",
          "label": "全局设置服务",
          "logicalService": "platform.settings",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.settings", "read": ["list"], "write": ["put", "delete"] }
          ]
        },
        {
          "id": "credentials",
          "label": "凭证管理服务",
          "logicalService": "platform.credentials",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.credentials", "read": ["list"], "write": ["put", "rotate", "revoke"] }
          ]
        },
        {
          "id": "database",
          "label": "数据库服务",
          "logicalService": "platform.database",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.database", "read": ["list"], "write": ["define", "remove", "probe"] }
          ]
        },
        {
          "id": "artifacts",
          "label": "制品仓库服务",
          "logicalService": "platform.artifacts.repository",
          "routingDomain": "platform",
          "capabilities": [
            { "capability": "platform.artifacts.repository", "read": ["status", "capacity", "listCatalog", "listPublishJournal", "resolve", "listReferences", "gcPlan", "gcStatus", "migrationStatus"], "write": ["setLifecycle", "gcQuarantine", "gcSweep", "prepareMigration", "syncMigration", "cutoverMigration", "rollbackMigration", "finalizeMigration", "releaseMigration"] }
          ]
        },
        {
          "id": "deployment",
