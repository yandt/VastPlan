{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/deployment/v2/vastplan.deployment.schema.json",
  "title": "VastPlan Cluster Deployment v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "metadata", "units"],
  "properties": {
    "version": { "const": 2 },
    "revision": { "type": "integer", "minimum": 1 },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "tenant": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "units": {
      "type": "array",
      "items": { "$ref": "#/$defs/serviceUnit" }
    }
  },
  "$defs": {
    "pluginRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodeSelector": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "affinity": { "$ref": "#/$defs/labelPolicy" },
        "antiAffinity": { "$ref": "#/$defs/labelPolicy" }
      }
    },
    "labelTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_labels"],
      "properties": {
        "match_labels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "weightedLabelTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_labels", "weight"],
      "properties": {
        "match_labels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "weight": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "labelPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "array", "items": { "$ref": "#/$defs/labelTerm" } },
        "preferred": { "type": "array", "items": { "$ref": "#/$defs/weightedLabelTerm" } }
      }
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu_millis": { "type": "integer", "minimum": 0 },
        "memory_bytes": { "type": "integer", "minimum": 0 },
        "gpu": { "type": "integer", "minimum": 0 }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": { "$ref": "#/$defs/resourceList" }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_replicas", "max_replicas", "metric", "target_value_per_replica"],
      "properties": {
        "min_replicas": { "type": "integer", "minimum": 1 },
        "max_replicas": { "type": "integer", "minimum": 1 },
        "metric": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._-]{0,127}$" },
        "target_value_per_replica": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "serviceUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "plugins", "enabled", "service_role", "replicas"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
        "kind": { "const": "service" },
        "plugins": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/pluginRef" }
        },
        "config": { "type": "object" },
        "enabled": { "type": "boolean" },
        "service_role": { "enum": ["backend", "workspace", "rs"] },
        "replicas": { "type": "integer", "minimum": 1 },
        "autoscaling": { "$ref": "#/$defs/autoscaling" },
        "resources": { "$ref": "#/$defs/resources" },
        "placement": { "$ref": "#/$defs/placement" }
      }
    }
  }
}
