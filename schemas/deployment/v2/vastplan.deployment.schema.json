{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/deployment/v2/vastplan.deployment.schema.json",
  "title": "VastPlan Cluster Deployment v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "metadata", "resolution", "units"],
  "properties": {
    "version": { "const": 2 },
    "revision": { "type": "integer", "minimum": 1 },
    "metadata": { "$ref": "#/$defs/deploymentMetadata" },
    "resolution": { "$ref": "#/$defs/resolution" },
    "units": {
      "type": "array",
      "items": { "$ref": "#/$defs/serviceUnit" }
    },
    "app_profiles": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/appProfileRef" }
    }
  },
  "$defs": {
    "deploymentMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 160 },
        "tenant": { "type": "string", "minLength": 1, "maxLength": 160 }
      }
    },
    "compositionRef": {
      "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/compositionRef"
    },
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["platform_profile", "application_composition", "development_mode", "plugin_origins"],
      "properties": {
        "platform_profile": { "$ref": "#/$defs/compositionRef" },
        "application_composition": { "$ref": "#/$defs/compositionRef" },
        "development_mode": { "type": "boolean" },
        "plugin_origins": {
          "type": "object",
          "propertyNames": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
          "additionalProperties": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/composition/common/v1/vastplan.composition-common.schema.json#/$defs/origin" }
        }
      }
    },
    "appProfileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "revision", "digest"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
        "revision": { "type": "integer", "minimum": 1 },
        "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "pluginRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" }
      }
    },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nodeSelector": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "affinity": { "$ref": "#/$defs/labelPolicy" },
        "antiAffinity": { "$ref": "#/$defs/labelPolicy" }
      }
    },
    "labelTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_labels"],
      "properties": {
        "match_labels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "weightedLabelTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_labels", "weight"],
      "properties": {
        "match_labels": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "weight": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "labelPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "array", "items": { "$ref": "#/$defs/labelTerm" } },
        "preferred": { "type": "array", "items": { "$ref": "#/$defs/weightedLabelTerm" } }
      }
    },
    "resourceList": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cpu_millis": { "type": "integer", "minimum": 0 },
        "memory_bytes": { "type": "integer", "minimum": 0 },
        "gpu": { "type": "integer", "minimum": 0 }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": { "$ref": "#/$defs/resourceList" }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_replicas", "max_replicas", "metric", "target_value_per_replica"],
      "properties": {
        "min_replicas": { "type": "integer", "minimum": 1 },
        "max_replicas": { "type": "integer", "minimum": 1 },
        "metric": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9._-]{0,127}$" },
        "target_value_per_replica": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "serviceUnit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "plugins", "enabled", "service_role", "replicas"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
        "kind": { "const": "service" },
        "plugins": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/pluginRef" }
        },
        "config": { "type": "object" },
        "enabled": { "type": "boolean" },
        "service_role": { "enum": ["backend", "workspace", "rs"] },
        "logical_service": { "type": "string", "minLength": 1, "maxLength": 160 },
        "instance_policy": { "enum": ["per-kernel", "active-active", "leader", "partitioned"] },
        "state_model": { "enum": ["local-ephemeral", "external-shared", "leader-owned", "partition-owned"] },
        "visibility": { "enum": ["local", "service", "cluster", "global"] },
        "routing": { "enum": ["direct", "queue", "leader", "shard"] },
        "routing_domain": { "type": "string", "minLength": 1, "maxLength": 160 },
        "partition_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "depends_on": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 160 } },
        "replicas": { "type": "integer", "minimum": 1 },
        "autoscaling": { "$ref": "#/$defs/autoscaling" },
        "resources": { "$ref": "#/$defs/resources" },
        "placement": { "$ref": "#/$defs/placement" }
      }
    }
  }
}
