{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json",
  "title": "VastPlan Common Identifiers v1",
  "$defs": {
    "pluginId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)+$",
      "maxLength": 160
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "versionRange": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "channel": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
    },
    "entryPath": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        { "pattern": "^[^/].*$" },
        { "not": { "pattern": "(^|/)\\.\\.(/|$)" } }
      ]
    }
  }
}
