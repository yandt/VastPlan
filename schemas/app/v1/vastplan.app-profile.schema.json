{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/app/v1/vastplan.app-profile.schema.json",
  "title": "VastPlan Runner App Profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "id", "tenantId", "runtime", "targets", "distribution", "assignedTo", "plugins"],
  "properties": {
    "version": { "const": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "tenantId": { "type": "string", "minLength": 1, "maxLength": 160 },
    "runtime": { "const": "runner" },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^(darwin|linux|windows)/(amd64|arm64)$" }
    },
    "distribution": { "const": "self-update" },
    "assignedTo": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 160 }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/pluginRef" }
    },
    "config": { "type": "object" }
  },
  "$defs": {
    "pluginRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version"],
      "properties": {
        "id": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/pluginId" },
        "version": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/semver" },
        "channel": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/common/v1/identifiers.schema.json#/$defs/channel", "default": "stable" }
      }
    }
  }
}
