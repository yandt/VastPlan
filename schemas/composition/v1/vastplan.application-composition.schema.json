{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cdsoft.com.cn/vastplan/composition/v1/vastplan.application-composition.schema.json",
  "title": "VastPlan Backend Application Composition v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "revision", "id", "kernel", "metadata", "units"],
  "properties": {
    "version": { "const": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$" },
    "kernel": { "const": "backend" },
    "metadata": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/deployment/v2/vastplan.deployment.schema.json#/$defs/deploymentMetadata" },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["serviceClass", "spec"],
        "properties": {
          "serviceClass": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,127}$" },
          "spec": { "$ref": "https://schemas.cdsoft.com.cn/vastplan/deployment/v2/vastplan.deployment.schema.json#/$defs/serviceUnit" }
        }
      }
    }
  }
}
