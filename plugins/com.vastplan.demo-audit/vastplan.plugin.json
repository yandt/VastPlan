{
  "id": "com.vastplan.demo-audit",
  "name": "示例审计",
  "version": "0.1.0",
  "publisher": "vastplan",
  "description": "演示 fanout 分发：订阅 task.* 事件并记录，另提供工具查询已记录的事件",
  "engines": { "backend": "^0.1 || ^1.0" },

  "capabilities": { "kernelServices": [], "credentials": [], "resources": [] },

  "activation": ["onStartup"],

  "entry": { "backend": "backend/demo-audit" },

  "contributes": {
    "backend": {
      "eventSinks": [
        {
          "id": "demo.audit.sink",
          "service_role": "backend",
          "title": "审计事件汇",
          "priority": 50,
          "subscribe": ["task.*", "plugin.activated"]
        }
      ],
      "tools": [
        {
          "id": "demo.audit",
          "service_role": "backend",
          "title": "审计查询",
          "subcommands": [
            { "name": "list", "description": "列出已记录的事件类型" }
          ]
        }
      ]
    }
  }
}
