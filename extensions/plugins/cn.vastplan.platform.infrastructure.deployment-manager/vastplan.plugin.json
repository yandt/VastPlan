{
  "id": "cn.vastplan.platform.infrastructure.deployment-manager",
  "name": "VastPlan 部署与测试发布管理服务",
  "version": "0.14.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "管理非敏感节点引导、应用服务修订和 Backend 测试发布；凭证、制品信任、KV 与就绪事实仍由可信内核持有",
  "engines": { "backend": "^0.1", "frontend": "^1.0" },
  "capabilities": { "kernelServices": ["kernel.node.bootstrap", "kernel.node.readiness", "kernel.deployment.targets", "kernel.deployment.preview", "kernel.deployment.publish", "kernel.deployment.readiness"], "credentials": [], "resources": [] },
  "contextAccess": { "required": ["scope.tenant", "caller", "subject.id", "authorization.roles"], "optional": ["scope.project", "scene", "trace", "request.deadline", "request.idempotency", "propagation.callPath"] },
  "authorization": {
    "namespace": "platform.deployment",
    "permissions": [
      { "code": "platform.deployment.read", "title": "查看服务与节点", "scope": "platform", "risk": "low", "assignable": true, "offlineAllowed": false },
      { "code": "platform.deployment.write", "title": "维护节点计划", "scope": "platform", "risk": "high", "assignable": true, "offlineAllowed": false },
      { "code": "platform.deployment.bootstrap", "title": "申请节点引导", "scope": "platform", "risk": "high", "assignable": true, "offlineAllowed": false },
      { "code": "platform.deployment.approve", "title": "审批部署变更", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false },
      { "code": "platform.deployment.compose", "title": "编辑服务组合", "scope": "platform", "risk": "high", "assignable": true, "offlineAllowed": false },
      { "code": "platform.deployment.publish", "title": "发布或回滚服务", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false },
      { "code": "platform.deployment.test-target", "title": "管理测试发布目标", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false }
    ],
    "operationGuards": [
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listNodes", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listBootstrapJobs", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listDeploymentTargets", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listServiceRevisions", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listServiceRevisionAudit", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listTestTargetBindings", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "listTestReleases", "permissions": ["platform.deployment.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "putNode", "permissions": ["platform.deployment.write"], "access": "write", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "createBootstrap", "permissions": ["platform.deployment.bootstrap"], "access": "write", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "approveBootstrap", "permissions": ["platform.deployment.approve"], "access": "approve", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "createServiceDraft", "permissions": ["platform.deployment.compose"], "access": "write", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "updateServiceDraft", "permissions": ["platform.deployment.compose"], "access": "write", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "submitServiceDraft", "permissions": ["platform.deployment.compose"], "access": "write", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "approveServiceRevision", "permissions": ["platform.deployment.approve"], "access": "approve", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "publishServiceRevision", "permissions": ["platform.deployment.publish"], "access": "execute", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "rollbackServiceRevision", "permissions": ["platform.deployment.publish"], "access": "execute", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "putTestTargetBinding", "permissions": ["platform.deployment.test-target"], "access": "write", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "createTestRelease", "permissions": ["platform.deployment.publish"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.deployment", "operation": "rollbackTestRelease", "permissions": ["platform.deployment.publish"], "access": "execute", "approval": "none" }
    ]
  },
  "runtime": {
    "instancePolicy": "leader",
    "stateModel": "leader-owned",
    "visibility": "cluster",
    "routing": "leader",
    "routingDomain": "platform",
    "requires": [
      { "capability": "platform.settings", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.settings", "routingDomain": "platform" },
      { "capability": "platform.credentials", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.credentials", "routingDomain": "platform" },
      { "capability": "platform.artifacts.repository", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.artifacts.repository", "routingDomain": "platform" }
    ],
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.deployment", "visibility": "cluster", "routing": "leader", "routingDomain": "platform" }]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "state": { "backend": { "format": "cn.vastplan.platform.deployment-manager", "formatVersion": 4 } },
  "activation": ["onStartup", "onPortalStartup"],
  "entry": { "backend": "backend/deployment-manager", "frontend": "frontend/dist/index.js" },
  "contributes": {
    "backend": {
      "tools": [{
        "id": "platform.deployment",
        "service_role": "backend",
        "title": "部署与测试发布管理",
        "subcommands": [
          { "name": "listNodes", "description": "列出当前租户的节点计划", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "putNode", "description": "以 CAS 保存不含明文凭证的节点计划", "paramsSchema": { "type": "object", "properties": { "id": { "type": "string" }, "plan": { "type": "object" }, "ifVersion": { "type": "integer", "minimum": 0 } }, "required": ["id", "plan"] } },
          { "name": "listBootstrapJobs", "description": "列出首次引导审批作业", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "createBootstrap", "description": "申请指定节点的首次引导", "paramsSchema": { "type": "object", "properties": { "nodeId": { "type": "string" } }, "required": ["nodeId"] } },
          { "name": "approveBootstrap", "description": "由不同审批人批准并触发可信内核引导", "paramsSchema": { "type": "object", "properties": { "jobId": { "type": "string" } }, "required": ["jobId"] } },
          { "name": "listDeploymentTargets", "description": "列出平台预授权的部署目标", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "listServiceRevisions", "description": "列出服务组合修订", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "createServiceDraft", "description": "创建仅含应用配置的服务草稿", "paramsSchema": { "type": "object", "properties": { "composition": { "type": "object" } }, "required": ["composition"] } },
          { "name": "updateServiceDraft", "description": "更新服务组合草稿", "paramsSchema": { "type": "object", "properties": { "revisionId": { "type": "integer", "minimum": 1 }, "composition": { "type": "object" } }, "required": ["revisionId", "composition"] } },
          { "name": "submitServiceDraft", "description": "提交服务组合审批", "paramsSchema": { "type": "object", "properties": { "revisionId": { "type": "integer", "minimum": 1 } }, "required": ["revisionId"] } },
          { "name": "approveServiceRevision", "description": "批准服务组合修订", "paramsSchema": { "type": "object", "properties": { "revisionId": { "type": "integer", "minimum": 1 } }, "required": ["revisionId"] } },
          { "name": "publishServiceRevision", "description": "通过可信内核发布服务组合", "paramsSchema": { "type": "object", "properties": { "revisionId": { "type": "integer", "minimum": 1 } }, "required": ["revisionId"] } },
          { "name": "rollbackServiceRevision", "description": "以新修订回滚到历史服务组合", "paramsSchema": { "type": "object", "properties": { "revisionId": { "type": "integer", "minimum": 1 } }, "required": ["revisionId"] } },
          { "name": "createConfigurationActivation", "description": "从活动可信目录创建应用插件配置审批修订", "paramsSchema": { "type": "object", "additionalProperties": false, "properties": { "activation": { "type": "object" } }, "required": ["activation"] } },
          { "name": "getConfigurationActivation", "description": "按配置候选读取外部发布与就绪状态", "paramsSchema": { "type": "object", "additionalProperties": false, "properties": { "candidateId": { "type": "string" } }, "required": ["candidateId"] } },
          { "name": "publishConfigurationActivation", "description": "发布已审批配置修订并在 readiness 失败时单调回滚", "paramsSchema": { "type": "object", "additionalProperties": false, "properties": { "candidateId": { "type": "string" } }, "required": ["candidateId"] } },
          { "name": "listServiceRevisionAudit", "description": "列出服务组合审计记录", "paramsSchema": { "type": "object", "properties": { "revisionId": { "type": "integer", "minimum": 1 } }, "required": ["revisionId"] } },
          { "name": "listTestTargetBindings", "description": "列出 Backend 测试目标预授权绑定", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "putTestTargetBinding", "description": "以 CAS 保存 Backend 应用插件测试目标绑定", "paramsSchema": { "type": "object", "properties": { "id": { "type": "string" }, "binding": { "type": "object" } }, "required": ["id", "binding"] } },
          { "name": "listTestReleases", "description": "列出测试发布与自动回滚状态", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "createTestRelease", "description": "验证精确 testing 制品并执行候选发布", "paramsSchema": { "type": "object", "properties": { "release": { "type": "object" } }, "required": ["release"] } },
          { "name": "rollbackTestRelease", "description": "恢复回滚被中断的测试发布", "paramsSchema": { "type": "object", "properties": { "releaseId": { "type": "integer", "minimum": 1 } }, "required": ["releaseId"] } }
        ]
      }]
    },
    "frontend": {
      "views": [{ "id": "platform.deployment", "title": "服务与节点部署" }],
      "menus": [{ "id": "platform.deployment.menu", "title": "服务与节点部署" }]
    }
  }
}
