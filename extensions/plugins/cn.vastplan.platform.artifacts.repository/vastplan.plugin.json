{
  "id": "cn.vastplan.platform.artifacts.repository",
  "name": "VastPlan 制品仓库服务",
  "version": "0.18.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "提供签名 HTTPS 制品、确定性依赖锁、生命周期与引用保护、离线 Bundle 及可回滚存储迁移；内核仍独占验签和安装授权",
  "engines": { "backend": "^0.1", "frontend": "^1.0" },
  "capabilities": { "kernelServices": [], "credentials": [], "resources": [] },
  "contextAccess": { "optional": ["scope.tenant", "caller", "scene", "trace", "request.deadline", "propagation.callPath"] },
  "authorization": {
    "namespace": "platform.artifacts",
    "permissions": [
      { "code": "platform.artifacts.read", "title": "查看制品仓库", "description": "查看仓库状态、目录、发布流水、引用、容量和只读计划", "scope": "platform", "risk": "low", "assignable": true, "offlineAllowed": false },
      { "code": "platform.artifacts.lifecycle", "title": "管理制品生命周期", "description": "变更制品 deprecated、yanked 或 revoked 生命周期", "scope": "platform", "risk": "high", "assignable": true, "offlineAllowed": false },
      { "code": "platform.artifacts.gc", "title": "执行制品回收", "description": "隔离或永久清扫无引用制品", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false },
      { "code": "platform.artifacts.migrate", "title": "迁移制品仓库", "description": "准备、切换、回滚和释放制品存储卷", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false }
    ],
    "operationGuards": [
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "status", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "capacity", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "listCatalog", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "listPublishJournal", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "resolve", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "listReferences", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "gcPlan", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "gcStatus", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "migrationStatus", "permissions": ["platform.artifacts.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "setLifecycle", "permissions": ["platform.artifacts.lifecycle"], "access": "write", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "gcQuarantine", "permissions": ["platform.artifacts.gc"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "gcSweep", "permissions": ["platform.artifacts.gc"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "prepareMigration", "permissions": ["platform.artifacts.migrate"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "syncMigration", "permissions": ["platform.artifacts.migrate"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "cutoverMigration", "permissions": ["platform.artifacts.migrate"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "rollbackMigration", "permissions": ["platform.artifacts.migrate"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "finalizeMigration", "permissions": ["platform.artifacts.migrate"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "operation": "releaseMigration", "permissions": ["platform.artifacts.migrate"], "access": "execute", "approval": "none" }
    ]
  },
  "runtime": {
    "instancePolicy": "leader",
    "stateModel": "leader-owned",
    "visibility": "cluster",
    "routing": "leader",
    "routingDomain": "platform",
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.artifacts.repository", "visibility": "cluster", "routing": "leader", "routingDomain": "platform" }],
    "requires": [{ "capability": "platform.api-exposure", "scope": "remote", "kind": "soft", "ready": "readiness", "failurePolicy": "degrade", "logicalService": "platform.api-exposure", "routingDomain": "platform" }]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "configuration": {
    "scope": "service",
    "applyMode": "restart",
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "listen": { "type": "string", "minLength": 1 },
        "storageProvider": { "type": "string", "minLength": 1, "maxLength": 160 },
        "volumeId": { "type": "string", "minLength": 1, "maxLength": 80 },
        "apiExposure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "exposureId": { "type": "string", "pattern": "^dpx_[a-z2-7]{20}$" },
            "instanceId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,159}$" },
            "endpoint": { "type": "string", "pattern": "^https://", "maxLength": 2048 },
            "tlsIdentity": { "type": "string", "pattern": "^spiffe://", "maxLength": 512 }
          },
          "required": ["exposureId", "instanceId", "endpoint", "tlsIdentity"]
        },
        "quota": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxArtifacts": { "type": "integer", "minimum": 0 },
            "maxBytes": { "type": "integer", "minimum": 0 },
            "rules": {
              "type": "array",
              "maxItems": 256,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,79}$" },
                  "namespace": { "type": "string", "pattern": "^[a-z][a-z0-9.-]{0,159}$" },
                  "publisher": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{0,159}$" },
                  "channel": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" },
                  "maxArtifacts": { "type": "integer", "minimum": 0 },
                  "maxBytes": { "type": "integer", "minimum": 0 }
                },
                "required": ["id"],
                "allOf": [
                  { "anyOf": [{ "required": ["namespace"] }, { "required": ["publisher"] }, { "required": ["channel"] }] },
                  { "anyOf": [{ "properties": { "maxArtifacts": { "minimum": 1 } }, "required": ["maxArtifacts"] }, { "properties": { "maxBytes": { "minimum": 1 } }, "required": ["maxBytes"] }] }
                ]
              }
            }
          }
        }
      },
      "required": ["storageProvider", "volumeId"]
    }
  },
  "state": { "backend": { "format": "cn.vastplan.platform.artifacts.repository", "formatVersion": 2 } },
  "activation": ["onStartup", "onPortalStartup"],
  "entry": { "backend": "backend/artifact-repository", "frontend": "frontend/dist/index.js" },
  "contributes": {
    "backend": {
      "tools": [{
        "id": "platform.artifacts.repository",
        "service_role": "backend",
        "title": "制品仓库",
        "subcommands": [
          { "name": "status", "description": "读取仓库运行状态" },
          { "name": "capacity", "description": "读取已验证容量与配额用量" },
          { "name": "listCatalog", "description": "分页查询已验证制品目录" },
          { "name": "listPublishJournal", "description": "按 revision 查询发布流水账" },
          { "name": "resolve", "description": "生成精确依赖锁" },
          { "name": "setLifecycle", "description": "以 CAS 更新制品生命周期" },
          { "name": "putReferences", "description": "发布完整制品引用快照" },
          { "name": "listReferences", "description": "读取制品引用保护状态" },
          { "name": "gcPlan", "description": "生成无副作用 GC 计划" },
          { "name": "gcStatus", "description": "读取隔离与清扫状态" },
          { "name": "gcQuarantine", "description": "按精确计划隔离制品" },
          { "name": "gcSweep", "description": "复核并清扫过期隔离制品" },
          { "name": "migrationStatus", "description": "读取迁移状态" },
          { "name": "prepareMigration", "description": "准备候选 volume" },
          { "name": "syncMigration", "description": "追平候选 volume" },
          { "name": "cutoverMigration", "description": "原子切换候选 volume" },
          { "name": "rollbackMigration", "description": "回滚到源 volume" },
          { "name": "finalizeMigration", "description": "结束观察双写" },
          { "name": "releaseMigration", "description": "隔离旧 volume" }
          ,{ "name": "installDataPlaneTicket", "description": "安装控制面签发的一次性下载 Ticket" }
        ]
      }],
      "dataPlaneServices": [{
        "id": "artifact-data",
        "service_role": "backend",
        "title": "制品大对象 HTTPS 数据面",
        "protocol": "https",
        "purposes": ["artifact-download", "artifact-upload", "offline-bundle"],
        "supportedModes": ["ticket-redirect", "private-direct"],
        "healthPath": "/healthz",
        "maxObjectBytes": 1099511627776,
        "ticketTarget": { "capability": "platform.artifacts.repository", "operation": "installDataPlaneTicket" }
      }]
    },
    "frontend": {
      "views": [{ "id": "platform.artifact-repository", "title": "制品仓库" }],
      "menus": [{ "id": "platform.artifact-repository.menu", "title": "制品仓库" }]
    }
  }
}
