{
  "id": "cn.vastplan.foundation.security.authentication-broker",
  "name": "VastPlan Authentication Broker",
  "description": "按不可变 Provider Catalog 路由统一认证方法并约束事务所有权",
  "version": "0.1.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "engines": { "backend": "^0.1", "frontend": "^1.0" },
  "contextAccess": { "required": ["scope.tenant", "caller"], "optional": ["scene", "trace", "request.deadline", "request.idempotency", "propagation.callPath"] },
  "runtime": { "instancePolicy": "leader", "stateModel": "leader-owned", "visibility": "cluster", "routing": "leader", "routingDomain": "security" },
  "authorization": {
    "namespace": "foundation.security.authentication",
    "permissions": [
      { "code": "foundation.security.authentication.providers.broker.invoke", "title": "调用企业认证流程", "scope": "platform", "risk": "high", "assignable": false, "offlineAllowed": false },
      { "code": "foundation.security.authentication.providers.read", "title": "读取认证 Provider", "scope": "platform", "risk": "medium", "assignable": true, "offlineAllowed": false },
      { "code": "foundation.security.authentication.providers.edit", "title": "编辑认证 Provider 草稿", "scope": "platform", "risk": "high", "assignable": true, "offlineAllowed": false },
      { "code": "foundation.security.authentication.providers.test", "title": "测试认证 Provider", "scope": "platform", "risk": "high", "assignable": true, "offlineAllowed": false },
      { "code": "foundation.security.authentication.providers.approve", "title": "批准认证 Provider", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false },
      { "code": "foundation.security.authentication.providers.publish", "title": "发布认证 Provider Catalog", "scope": "platform", "risk": "critical", "assignable": true, "offlineAllowed": false }
    ],
    "operationGuards": [
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "describe", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "begin", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "continue", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "resend", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "cancel", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "health", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "consumeAssertion", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.broker", "operation": "beginProviderTest", "permissions": ["foundation.security.authentication.providers.broker.invoke"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "get", "permissions": ["foundation.security.authentication.providers.read"], "access": "read", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "createDraft", "permissions": ["foundation.security.authentication.providers.edit"], "access": "write", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "validate", "permissions": ["foundation.security.authentication.providers.edit"], "access": "write", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "recordTest", "permissions": ["foundation.security.authentication.providers.test"], "access": "execute", "approval": "none" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "approve", "permissions": ["foundation.security.authentication.providers.approve"], "access": "approve", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "publish", "permissions": ["foundation.security.authentication.providers.publish"], "access": "approve", "approval": "different-subject" },
      { "extensionPoint": "tool.package", "capability": "foundation.security.authentication.providers", "operation": "retire", "permissions": ["foundation.security.authentication.providers.edit"], "access": "write", "approval": "none" }
    ]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "activation": ["onStartup", "onPortalStartup"],
  "entry": { "backend": "backend/authentication-broker", "frontend": "frontend/dist/index.js" },
  "contributes": { "backend": { "tools": [{
    "id": "foundation.security.authentication.broker",
    "service_role": "backend",
    "title": "企业认证 Broker",
    "subcommands": [
      { "name": "describe", "description": "列出门户允许的认证方式" },
      { "name": "begin", "description": "开始认证事务" },
      { "name": "continue", "description": "继续认证事务" },
      { "name": "resend", "description": "重发认证挑战" },
      { "name": "cancel", "description": "取消认证事务" },
      { "name": "health", "description": "检查认证 Provider" },
      { "name": "consumeAssertion", "description": "原子消费 Broker Assertion" },
      { "name": "beginProviderTest", "description": "对已验证草稿发起隔离认证测试" }
    ]
  }, {
    "id": "foundation.security.authentication.providers",
    "service_role": "backend",
    "title": "认证 Provider 目录管理",
    "subcommands": [
      { "name": "get", "description": "读取 Provider 管理状态" },
      { "name": "createDraft", "description": "创建不可变 Provider Profile 草稿" },
      { "name": "validate", "description": "验证 Provider Profile" },
      { "name": "recordTest", "description": "记录隔离认证测试" },
      { "name": "approve", "description": "批准已测试 Provider" },
      { "name": "publish", "description": "原子发布 Provider Catalog 与门户 Binding" },
      { "name": "retire", "description": "退役 Provider" }
    ]
  }] }, "frontend": {
    "views": [{ "id": "foundation.security.authentication.providers", "title": "企业认证 Provider" }],
    "menus": [{ "id": "foundation.security.authentication.providers.menu", "title": "企业认证 Provider" }]
  } }
}
