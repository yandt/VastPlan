{
  "id": "com.vastplan.platform.security.credentials",
  "name": "VastPlan 凭证管理服务",
  "version": "0.2.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "使用 Vault Transit/KMS 信封加密保存凭证密文；任何插件调用均不可读取凭证明文",
  "engines": { "backend": "^1.0", "frontend": "^1.0" },
  "capabilities": { "kernelServices": ["kernel.config.get"], "credentials": [], "resources": [] },
  "contextAccess": { "required": ["scope.tenant", "caller"], "optional": ["scene", "trace", "request.deadline", "request.idempotency", "propagation.callPath"] },
  "runtime": {
    "instancePolicy": "leader", "stateModel": "leader-owned", "visibility": "cluster", "routing": "leader", "routingDomain": "platform",
    "requires": [{ "capability": "platform.settings", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.settings", "routingDomain": "platform" }],
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.credentials", "visibility": "cluster", "routing": "leader", "routingDomain": "platform" }]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "state": { "backend": { "format": "com.vastplan.platform.credentials", "formatVersion": 1 } },
  "activation": ["onStartup", "onPortalStartup"],
  "entry": { "backend": "backend/credentials", "frontend": "frontend/dist/index.js" },
  "contributes": { "backend": { "tools": [{ "id": "platform.credentials", "service_role": "backend", "title": "凭证管理", "subcommands": [
    { "name": "put", "description": "以 Vault Transit 加密后保存凭证", "paramsSchema": { "type": "object", "properties": { "name": { "type": "string" }, "value": { "type": "string" } }, "required": ["name", "value"] } },
    { "name": "describe", "description": "读取凭证元数据，不返回明文或密文", "paramsSchema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } },
    { "name": "list", "description": "列出当前租户的凭证元数据", "paramsSchema": { "type": "object", "properties": { "prefix": { "type": "string" } } } },
    { "name": "rotate", "description": "通过 Vault Transit rewrap 轮换凭证包裹密钥", "paramsSchema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } },
    { "name": "revoke", "description": "撤销凭证引用", "paramsSchema": { "type": "object", "properties": { "name": { "type": "string" } }, "required": ["name"] } }
  ] }] }, "frontend": {
    "views": [{ "id": "platform.credentials", "title": "凭证引用" }],
    "menus": [{ "id": "platform.credentials.menu", "title": "凭证引用" }]
  } }
}
