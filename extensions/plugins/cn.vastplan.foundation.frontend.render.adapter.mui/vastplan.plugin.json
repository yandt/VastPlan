{
  "id": "cn.vastplan.foundation.frontend.render.adapter.mui",
  "name": "VastPlan MUI Design System",
  "description": "以 Material UI 实现 Portal 的框架无关 UI 契约",
  "version": "1.0.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "engines": { "frontend": "^1.0" },
  "capabilities": { "kernelServices": [], "credentials": [], "resources": [] },
  "activation": ["onPortalStartup"],
  "entry": { "frontend": "frontend/dist/index.js" },
  "contributes": {
    "frontend": {
      "renderAdapters": [{
        "id": "ui.render.adapter",
        "title": "Material UI Design System",
        "uiContract": "^4.0.0",
        "framework": "mui",
        "capabilities": ["layout", "menu", "overlay", "form", "data", "feedback", "theme", "navigation"]
      }]
    }
  }
}
