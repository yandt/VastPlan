{
  "id": "cn.vastplan.hello-world",
  "name": "Hello World",
  "version": "0.2.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "MVP 骨架验证插件：向 Agent 暴露一个工具包，验证握手→贡献注册→调用闭环",
  "engines": { "backend": "^0.1 || ^1.0" },

  "capabilities": {
    "kernelServices": ["kernel.info"],
    "credentials": [],
    "resources": []
  },
  "contextAccess": { "required": ["scope.tenant", "caller", "subject.profile", "trace"], "optional": ["scene", "request.deadline", "propagation.callPath"] },

  "runtime": {
    "instancePolicy": "active-active", "stateModel": "external-shared", "visibility": "cluster", "routing": "queue", "routingDomain": "application",
    "provides": [{ "extensionPoint": "tool.package", "capability": "vastplan.hello", "visibility": "cluster", "routing": "queue", "routingDomain": "application" }],
    "requires": [{ "capability": "configuration.scoped", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.plugin-configuration", "routingDomain": "platform" }]
  },

  "configuration": {
    "scope": "tenant", "applyMode": "hot",
    "schema": {
      "type": "object", "additionalProperties": false,
      "required": ["greetingTemplate"],
      "properties": {
        "greetingTemplate": { "type": "string", "minLength": 10, "maxLength": 256, "pattern": "\\{\\{name\\}\\}" }
      }
    }
  },

  "activation": ["onAgentTool:vastplan.hello"],

  "entry": { "backend": "backend/hello-world" },

  "contributes": {
    "backend": {
      "tools": [
        {
          "id": "vastplan.hello",
          "service_role": "backend",
          "title": "Hello 工具包",
          "subcommands": [
            {
              "name": "greet",
              "description": "向指定对象问好",
              "paramsSchema": {
                "type": "object",
                "properties": { "name": { "type": "string" } },
                "required": ["name"]
              }
            },
            {
              "name": "echo",
              "description": "原样回显",
              "paramsSchema": {
                "type": "object",
                "properties": { "text": { "type": "string" } },
              "required": ["text"]
              }
            },
            {
              "name": "whoami",
              "description": "回调宿主取内核信息"
            }
          ]
        }
      ]
    }
  }
}
