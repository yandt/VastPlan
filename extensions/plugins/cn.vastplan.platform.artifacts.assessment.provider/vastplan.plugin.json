{
  "id": "cn.vastplan.platform.artifacts.assessment.provider",
  "name": "VastPlan Artifact Security Assessment Provider",
  "version": "0.3.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "在独立可信进程中通过一次性扫描租约读取制品、离线运行 Trivy，并使用 Material Lease 私钥签署安全准入记录",
  "engines": { "backend": "^0.1" },
  "capabilities": { "kernelServices": ["kernel.credential.material-lease"], "credentials": ["artifact.assessment.signing-key"], "resources": ["network.internal", "process.scanner"] },
  "contextAccess": { "required": ["scope.tenant", "caller"], "optional": ["trace", "request.deadline", "request.idempotency", "propagation.callPath"] },
  "runtime": {
    "instancePolicy": "active-active", "stateModel": "external-shared", "visibility": "cluster", "routing": "queue", "routingDomain": "platform",
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.artifacts.assessment", "visibility": "cluster", "routing": "queue", "routingDomain": "platform" }],
    "requires": [
      { "capability": "platform.artifacts.repository", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.artifacts.repository", "routingDomain": "platform" },
      { "capability": "platform.artifacts.assessment.database.file", "scope": "same-node", "kind": "data", "ready": "readiness", "failurePolicy": "fail" }
    ]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "configuration": {
    "scope": "service", "applyMode": "restart",
    "schema": {
      "type": "object", "additionalProperties": false,
      "required": ["providerId", "keyId", "signingKeyRef", "trivyBinary", "trivySnapshotDirectory", "scannerVersion", "databaseRevision", "workRoot", "reportArchiveDirectory", "ttlHours", "timeoutSeconds", "allowedLicenses", "fullLicenseScan", "maximum"],
      "properties": {
        "providerId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "keyId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "signingKeyRef": {
          "type": "object", "additionalProperties": false, "required": ["handle", "scope", "owner", "purpose", "version"],
          "properties": {
            "handle": { "type": "string", "pattern": "^credential://managed/", "maxLength": 256 },
            "scope": { "const": "tenant" },
            "owner": { "const": "cn.vastplan.platform.artifacts.assessment.provider" },
            "purpose": { "const": "artifact.assessment.signing-key" },
            "version": { "type": "integer", "minimum": 1 }
          }
        },
        "trivyBinary": { "type": "string", "pattern": "^/", "maxLength": 4096 },
        "trivySnapshotDirectory": { "type": "string", "pattern": "^/.*/snapshots/[a-f0-9]{64}$", "maxLength": 4096 },
        "scannerVersion": { "type": "string", "minLength": 1, "maxLength": 80 },
        "databaseRevision": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "workRoot": { "type": "string", "pattern": "^/", "maxLength": 4096 },
        "reportArchiveDirectory": { "type": "string", "pattern": "^/", "maxLength": 4096 },
        "ttlHours": { "type": "integer", "minimum": 1, "maximum": 8760, "default": 168 },
        "timeoutSeconds": { "type": "integer", "minimum": 1, "maximum": 7200, "default": 1200 },
        "allowedLicenses": { "type": "array", "minItems": 1, "maxItems": 256, "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 160 } },
        "fullLicenseScan": { "type": "boolean", "default": true },
        "maximum": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "critical": { "type": "integer", "minimum": 0 }, "high": { "type": "integer", "minimum": 0 },
            "medium": { "type": "integer", "minimum": 0 }, "low": { "type": "integer", "minimum": 0 },
            "unknownVulnerability": { "type": "integer", "minimum": 0 }, "deniedLicense": { "type": "integer", "minimum": 0 },
            "unknownLicense": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  },
  "activation": ["onStartup"],
  "entry": { "backend": "backend/artifact-assessment-provider" },
  "contributes": { "backend": { "tools": [{ "id": "platform.artifacts.assessment", "service_role": "backend", "title": "插件制品安全评估 Provider", "subcommands": [{ "name": "status", "description": "读取扫描器与评估策略 revision" }, { "name": "assessAdmission", "description": "扫描精确制品并签署不可变准入记录" }, { "name": "assessStatus", "description": "复扫精确制品并签署只追加状态记录" }] }] } }
}
