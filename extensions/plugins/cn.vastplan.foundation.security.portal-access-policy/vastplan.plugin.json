{
  "id": "cn.vastplan.foundation.security.portal-access-policy",
  "name": "VastPlan 门户访问策略",
  "version": "0.3.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "以经验证角色控制 Portal Composer，并限制用户偏好只能来自可信 Portal BFF",
  "engines": { "backend": "^0.1" },
  "capabilities": { "kernelServices": [], "credentials": [], "resources": [] },
  "contextAccess": {
    "required": ["caller", "authorization.roles"],
    "optional": ["scope.tenant", "scene", "subject.id", "trace", "request.deadline", "propagation.callPath"]
  },
  "runtime": { "instancePolicy": "per-kernel", "stateModel": "local-ephemeral", "visibility": "local", "routing": "direct" },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "activation": ["onStartup"],
  "entry": { "backend": "backend/portal-access-policy" },
  "contributes": {
    "backend": {
      "permissionCheckers": [{
        "id": "foundation.security.portal-access-policy",
        "service_role": "backend",
        "title": "门户角色访问策略",
        "priority": 1000,
        "applies": {}
      }]
    }
  }
}
