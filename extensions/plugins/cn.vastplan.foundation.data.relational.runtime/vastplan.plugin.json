{
  "id": "cn.vastplan.foundation.data.relational.runtime",
  "name": "VastPlan Database Runtime",
  "version": "0.6.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "内置 PostgreSQL/MySQL Provider、连接池、按 revision 发布及实例亲和事务的数据面基础插件",
  "engines": { "backend": "^0.1" },
  "capabilities": { "kernelServices": ["kernel.credential.material-lease"], "credentials": [], "resources": [] },
  "contextAccess": {
    "required": ["caller"],
    "optional": ["scope.tenant", "scope.project", "scene", "trace", "request.deadline", "request.idempotency", "grant.credentials", "propagation.callPath"]
  },
  "runtime": {
    "instancePolicy": "active-active",
    "stateModel": "external-shared",
    "visibility": "cluster",
    "routing": "queue",
    "routingDomain": "platform",
    "provides": [
      {
        "extensionPoint": "tool.package",
        "capability": "foundation.data.relational.runtime",
        "visibility": "cluster",
        "routing": "queue",
        "routingDomain": "platform"
      }
    ]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "configuration": {
    "scope": "service",
    "applyMode": "restart",
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowInsecureTLS": { "type": "boolean", "default": false },
        "maxTransactions": { "type": "integer", "minimum": 1, "maximum": 1000000, "default": 4096 }
      }
    }
  },
  "activation": ["onStartup"],
  "entry": { "backend": "backend/database-runtime" },
  "contributes": {
    "backend": {
      "tools": [
        {
          "id": "foundation.data.relational.runtime",
          "service_role": "backend",
          "title": "Database Runtime",
          "subcommands": [
            {
              "name": "providers",
              "description": "列出当前制品内已注册的关系数据库 Provider",
              "paramsSchema": { "type": "object", "additionalProperties": false, "maxProperties": 0 }
            },
            { "name": "probe", "description": "由连接管理面执行一次性连通性检查" },
            { "name": "activate", "description": "发布或轮换连接 revision" },
            { "name": "retire", "description": "排空并删除连接 revision" },
            { "name": "query", "description": "通过活动连接池或实例亲和事务执行参数化查询" },
            { "name": "execute", "description": "通过活动连接池或实例亲和事务执行参数化写操作" },
            { "name": "begin", "description": "在当前 Runtime 实例开始短期事务" },
            { "name": "commit", "description": "提交实例亲和事务" },
            { "name": "rollback", "description": "回滚实例亲和事务" }
          ]
        }
      ]
    }
  }
}
