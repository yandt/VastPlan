{
  "id": "com.vastplan.platform.infrastructure.deployment-manager",
  "name": "VastPlan 节点部署管理服务",
  "version": "0.2.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "保存非敏感节点计划和首次引导审批状态；凭证解析与 SSH 执行仅由可信内核完成",
  "engines": { "backend": "^0.1" },
  "capabilities": { "kernelServices": ["kernel.node.bootstrap", "kernel.node.readiness"], "credentials": [], "resources": [] },
  "contextAccess": { "required": ["scope.tenant", "caller", "subject.id", "authorization.roles"], "optional": ["scope.project", "scene", "trace", "request.deadline", "request.idempotency", "propagation.callPath"] },
  "runtime": {
    "instancePolicy": "leader",
    "stateModel": "leader-owned",
    "visibility": "cluster",
    "routing": "leader",
    "routingDomain": "platform",
    "requires": [
      { "capability": "platform.settings", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.settings", "routingDomain": "platform" },
      { "capability": "platform.credentials", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.credentials", "routingDomain": "platform" },
      { "capability": "platform.artifacts.repository", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.artifacts.repository", "routingDomain": "platform" }
    ],
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.deployment", "visibility": "cluster", "routing": "leader", "routingDomain": "platform" }]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "state": { "backend": { "format": "com.vastplan.platform.deployment-manager", "formatVersion": 1 } },
  "activation": ["onStartup", "onPortalStartup"],
  "entry": { "backend": "backend/deployment-manager" },
  "contributes": {
    "backend": {
      "tools": [{
        "id": "platform.deployment",
        "service_role": "backend",
        "title": "节点部署管理",
        "subcommands": [
          { "name": "listNodes", "description": "列出当前租户的节点计划", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "putNode", "description": "以 CAS 保存不含明文凭证的节点计划", "paramsSchema": { "type": "object", "properties": { "id": { "type": "string" }, "plan": { "type": "object" }, "ifVersion": { "type": "integer", "minimum": 0 } }, "required": ["id", "plan"] } },
          { "name": "listBootstrapJobs", "description": "列出首次引导审批作业", "paramsSchema": { "type": "object", "properties": {} } },
          { "name": "createBootstrap", "description": "申请指定节点的首次引导", "paramsSchema": { "type": "object", "properties": { "nodeId": { "type": "string" } }, "required": ["nodeId"] } },
          { "name": "approveBootstrap", "description": "由不同审批人批准并触发可信内核引导", "paramsSchema": { "type": "object", "properties": { "jobId": { "type": "string" } }, "required": ["jobId"] } }
        ]
      }]
    }
  }
}
