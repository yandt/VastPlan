{
  "id": "cn.vastplan.foundation.security.authorization-engine.native",
  "name": "VastPlan Native Authorization Engine",
  "description": "默认 Go authorization.engine.v1 Provider，提供有界 RBAC/ABAC 求值与 Decision Proof",
  "version": "0.1.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "engines": { "backend": "^0.1" },
  "contextAccess": { "required": ["caller"], "optional": ["trace", "request.deadline", "propagation.callPath"] },
  "runtime": { "instancePolicy": "leader", "stateModel": "leader-owned", "visibility": "cluster", "routing": "leader", "routingDomain": "security" },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "activation": ["onStartup"],
  "entry": { "backend": "backend/authorization-engine-native" },
  "contributes": { "backend": { "tools": [{ "id": "foundation.security.authorization-engine.native", "service_role": "backend", "title": "VastPlan Native Authorization Engine", "subcommands": [
    { "name": "prepare", "description": "准备签名策略快照" },
    { "name": "evaluate", "description": "求值并返回有界 Decision Proof" },
    { "name": "explain", "description": "解释本地 Decision Proof" },
    { "name": "health", "description": "读取 Engine Provider 健康状态" }
  ] }] } }
}
