{
  "id": "com.vastplan.demo-permission",
  "name": "示例权限策略",
  "version": "0.1.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "演示 select 分发：两个不同优先级的权限校验器（拒绝名单 + 基线策略）",
  "engines": { "backend": "^0.1 || ^1.0" },

  "capabilities": { "kernelServices": [], "credentials": [], "resources": [] },

  "activation": ["onStartup"],

  "entry": { "backend": "backend/demo-permission" },

  "contributes": {
    "backend": {
      "permissionCheckers": [
        {
          "id": "demo.denylist",
          "service_role": "backend",
          "title": "拒绝名单（高优先级）",
          "priority": 100,
          "applies": {}
        },
        {
          "id": "demo.baseline",
          "service_role": "backend",
          "title": "基线策略（低优先级）",
          "priority": 10,
          "applies": {}
        }
      ]
    }
  }
}
