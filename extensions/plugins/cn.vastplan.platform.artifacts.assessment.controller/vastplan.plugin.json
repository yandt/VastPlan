{
  "id": "cn.vastplan.platform.artifacts.assessment.controller",
  "name": "VastPlan Artifact Security Rescan Controller",
  "version": "0.1.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "以 fenced leader、持久计划、稳定抖动和有界退避持续复扫插件制品，不持有 Provider 签名私钥",
  "engines": { "backend": "^0.1" },
  "capabilities": { "kernelServices": ["kernel.state.shared.get", "kernel.state.shared.list", "kernel.state.shared.fenced.create", "kernel.state.shared.fenced.update"], "credentials": [], "resources": [] },
  "contextAccess": { "required": ["scope.tenant", "caller"], "optional": ["trace", "request.deadline", "request.idempotency", "propagation.callPath"] },
  "runtime": {
    "instancePolicy": "leader", "stateModel": "leader-owned", "visibility": "cluster", "routing": "leader", "routingDomain": "platform", "backgroundService": true,
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.artifacts.assessment.controller", "visibility": "cluster", "routing": "leader", "routingDomain": "platform" }],
    "requires": [
      { "capability": "platform.artifacts.repository", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.artifacts.repository", "routingDomain": "platform" },
      { "capability": "platform.artifacts.assessment", "scope": "remote", "kind": "strong", "ready": "readiness", "failurePolicy": "fail", "logicalService": "platform.artifacts.assessment", "routingDomain": "platform" }
    ]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "configuration": {
    "scope": "service", "applyMode": "restart",
    "schema": {
      "type": "object", "additionalProperties": false,
      "required": ["tenantId", "channels", "intervalSeconds", "leadTimeSeconds", "jitterSeconds", "retryBaseSeconds", "retryMaxSeconds", "pageSize"],
      "properties": {
        "tenantId": { "type": "string", "minLength": 1, "maxLength": 160 },
        "channels": { "type": "array", "minItems": 1, "maxItems": 16, "uniqueItems": true, "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$" } },
        "intervalSeconds": { "type": "integer", "minimum": 10, "maximum": 3600, "default": 60 },
        "leadTimeSeconds": { "type": "integer", "minimum": 60, "maximum": 2592000, "default": 86400 },
        "jitterSeconds": { "type": "integer", "minimum": 0, "maximum": 43200, "default": 3600 },
        "retryBaseSeconds": { "type": "integer", "minimum": 1, "maximum": 3600, "default": 30 },
        "retryMaxSeconds": { "type": "integer", "minimum": 1, "maximum": 86400, "default": 3600 },
        "pageSize": { "type": "integer", "minimum": 1, "maximum": 500, "default": 100 }
      }
    }
  },
  "state": { "backend": { "format": "cn.vastplan.artifacts.assessment.schedule", "formatVersion": 1 } },
  "activation": ["onStartup"],
  "entry": { "backend": "backend/artifact-assessment-controller" },
  "contributes": { "backend": { "tools": [{ "id": "platform.artifacts.assessment.controller", "service_role": "backend", "title": "插件制品持续复扫 Controller", "subcommands": [{ "name": "status", "description": "读取低基数调度状态" }] }] } }
}
