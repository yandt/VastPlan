  "configuration":{"scope":"service","applyMode":"hot","schema":{"type":"object","additionalProperties":false,"required":["profiles"],"properties":{"profiles":{"type":"object","minProperties":1,"maxProperties":64,"additionalProperties":{"type":"object","additionalProperties":false,"required":["endpoint","authorizationRef","channels"],"properties":{"endpoint":{"type":"string","format":"uri","pattern":"^https://","maxLength":2048},"authorizationRef":{"type":"object","additionalProperties":false,"required":["handle","scope","owner","purpose","version"],"properties":{"handle":{"type":"string","pattern":"^credential://managed/","maxLength":256},"scope":{"const":"tenant"},"owner":{"const":"cn.vastplan.platform.security.authentication.delivery.webhook"},"purpose":{"const":"authentication.delivery.webhook"},"version":{"type":"integer","minimum":1}}},"channels":{"type":"array","items":{"enum":["email","sms"]},"minItems":1,"maxItems":2,"uniqueItems":true},"timeoutMs":{"type":"integer","minimum":500,"maximum":15000,"default":5000}}}}}}},
