{
  "id": "cn.vastplan.platform.artifacts.assessment.database.file",
  "name": "VastPlan Trivy Database File Snapshot",
  "version": "0.1.0",
  "publisher": "vastplan",
  "license": "Apache-2.0",
  "licenseFile": "LICENSE",
  "noticeFile": "NOTICE",
  "description": "将私有本地 staging 中钉死摘要的 Trivy 数据库原子物化为每节点不可变快照",
  "engines": { "backend": "^0.1" },
  "capabilities": { "kernelServices": [], "credentials": [], "resources": ["filesystem.scanner-data"] },
  "contextAccess": { "optional": ["caller", "scene", "trace", "request.deadline"] },
  "runtime": {
    "instancePolicy": "per-kernel", "stateModel": "local-ephemeral", "visibility": "local", "routing": "direct",
    "provides": [{ "extensionPoint": "tool.package", "capability": "platform.artifacts.assessment.database.file", "visibility": "local", "routing": "direct" }]
  },
  "execution": { "backend": { "driver": "native", "minimumIsolation": "trusted-process" } },
  "configuration": {
    "scope": "service", "applyMode": "restart",
    "schema": {
      "type": "object", "title": "扫描数据库 File Source", "description": "从部署适配器准备的私有 staging 原子发布钉死摘要的本地快照", "additionalProperties": false,
      "required": ["sourceDirectory", "snapshotRoot", "databaseRevision"],
      "properties": {
        "sourceDirectory": { "type": "string", "title": "私有 Staging 目录", "description": "由部署适配器准备，必须包含 db/metadata.json 与 db/trivy.db", "pattern": "^/", "maxLength": 4096 },
        "snapshotRoot": { "type": "string", "title": "不可变快照根目录", "description": "物化结果写入 snapshots/<databaseRevision>，不得与 staging 重叠", "pattern": "^/", "maxLength": 4096 },
        "databaseRevision": { "type": "string", "title": "数据库内容 Revision", "description": "对规范相对路径和两个数据库文件字节计算的 SHA-256", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  },
  "activation": ["onStartup"],
  "entry": { "backend": "backend/artifact-assessment-database-file" },
  "contributes": { "backend": { "tools": [{ "id": "platform.artifacts.assessment.database.file", "service_role": "backend", "title": "Trivy 数据库 File Snapshot", "subcommands": [{ "name": "status", "description": "读取本节点已验证数据库 revision" }] }] } }
}
